# Maria Interno - Environment Variables

# Server
PORT=3001

# PostgreSQL Database
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=agora_production
PGPOOL_MAX=10

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Chatwoot Integration (optional)
CHATWOOT_API_KEY=your_chatwoot_api_key_here
CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1
