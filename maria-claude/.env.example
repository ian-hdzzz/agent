# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_api_key_here

# PostgreSQL Configuration for AGORA (Chatwoot)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=agora_production
PGPOOL_MAX=10

# CEA SOAP API Proxy (optional - for whitelisted IP access)
CEA_PROXY_URL=

# Server Configuration
PORT=3000
