# ===========================================
# MARIA V3 - Environment Configuration
# ===========================================

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (for Whisper transcription)
OPENAI_API_KEY=sk-...

# CEA SOAP API
CEA_API_BASE=https://aquacis-cf.ceaqueretaro.gob.mx/Comercial/services
CEA_PROXY_URL=                  # Optional proxy URL

# PostgreSQL (Chatwoot/AGORA database)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=agora_production
PGPOOL_MAX=10

# Chatwoot Integration
CHATWOOT_BASE_URL=https://chatwoot.example.com
CHATWOOT_API_TOKEN=

# Server Configuration
NODE_ENV=production
PORT=3000
LOG_LEVEL=info                  # debug, info, warn, error

# Memory & Storage
MEMORY_DB_PATH=./data/maria_memory.db
MEMORY_RETENTION_DAYS=30

# Rate Limiting
RATE_LIMIT_CONVERSATION=20      # Messages per minute per conversation
RATE_LIMIT_API=100              # Requests per minute per IP
RATE_LIMIT_BUDGET=50            # Requests per hour per IP

# Cache Configuration
CACHE_TTL_SECONDS=300           # 5 minutes default
CACHE_CHECK_PERIOD=60           # Cleanup interval

# Claude Model Configuration
CLAUDE_MODEL=claude-sonnet-4-5-20250929
MAX_BUDGET_PER_MESSAGE=0.50     # USD

# Runtime Context (set dynamically)
# CURRENT_CHATWOOT_ACCOUNT_ID=
# CURRENT_CHATWOOT_CONVERSATION_ID=
