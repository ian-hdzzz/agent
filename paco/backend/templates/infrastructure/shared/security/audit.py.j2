import logging
from datetime import datetime
from enum import Enum
from typing import Any

logger = logging.getLogger(__name__)


class AuditEventType(str, Enum):
    MESSAGE_RECEIVED = "message_received"
    MESSAGE_SENT = "message_sent"
    AGENT_CALL = "agent_call"
    PII_DETECTED = "pii_detected"
    TOOL_CALL = "tool_call"
    ERROR = "error"


class AuditLogger:
    def __init__(self):
        self.events: list[dict] = []

    async def connect(self):
        logger.info("Audit logger initialized")

    async def disconnect(self):
        pass

    async def log(
        self,
        event_type: AuditEventType,
        action: str,
        actor_type: str = "system",
        actor_ip: str | None = None,
        resource_type: str | None = None,
        resource_id: str | None = None,
        success: bool = True,
        details: dict[str, Any] | None = None,
    ):
        event = {
            "timestamp": datetime.utcnow().isoformat(),
            "event_type": event_type.value,
            "action": action,
            "actor_type": actor_type,
            "success": success,
            "details": details or {},
        }
        self.events.append(event)
        logger.debug(f"Audit: {event_type.value} - {action}")

    async def log_agent_call(
        self,
        agent_id: str,
        action: str,
        conversation_id: str | None = None,
        success: bool = True,
        details: dict[str, Any] | None = None,
    ):
        await self.log(
            event_type=AuditEventType.AGENT_CALL,
            action=action,
            resource_type="agent",
            resource_id=agent_id,
            success=success,
            details={**(details or {}), "conversation_id": conversation_id},
        )

    async def log_pii_detection(
        self,
        text_preview: str,
        pii_types: list[str],
        conversation_id: str | None = None,
        agent_id: str | None = None,
    ):
        await self.log(
            event_type=AuditEventType.PII_DETECTED,
            action="PII detected in message",
            details={"pii_types": pii_types, "agent_id": agent_id},
        )


_audit_logger: AuditLogger | None = None


def get_audit_logger() -> AuditLogger:
    global _audit_logger
    if _audit_logger is None:
        _audit_logger = AuditLogger()
    return _audit_logger
