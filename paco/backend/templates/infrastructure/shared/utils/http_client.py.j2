import logging
import time
from typing import Any

import httpx
from tenacity import retry, stop_after_attempt, wait_exponential

logger = logging.getLogger(__name__)


class CircuitOpenError(Exception):
    pass


class CircuitBreaker:
    def __init__(self, failure_threshold: int = 5, recovery_timeout: float = 30, half_open_max_calls: int = 3):
        self.failure_threshold = failure_threshold
        self.recovery_timeout = recovery_timeout
        self.half_open_max_calls = half_open_max_calls
        self.circuits: dict[str, dict[str, Any]] = {}

    def _get_circuit(self, service_id: str) -> dict[str, Any]:
        if service_id not in self.circuits:
            self.circuits[service_id] = {
                "state": "closed",
                "failures": 0,
                "last_failure": 0,
                "half_open_calls": 0,
            }
        return self.circuits[service_id]

    def is_available(self, service_id: str) -> bool:
        circuit = self._get_circuit(service_id)
        if circuit["state"] == "closed":
            return True
        if circuit["state"] == "open":
            if time.time() - circuit["last_failure"] > self.recovery_timeout:
                circuit["state"] = "half_open"
                circuit["half_open_calls"] = 0
                return True
            return False
        if circuit["state"] == "half_open":
            return circuit["half_open_calls"] < self.half_open_max_calls
        return True

    def record_success(self, service_id: str):
        circuit = self._get_circuit(service_id)
        if circuit["state"] == "half_open":
            circuit["half_open_calls"] += 1
            if circuit["half_open_calls"] >= self.half_open_max_calls:
                circuit["state"] = "closed"
                circuit["failures"] = 0
        else:
            circuit["failures"] = 0

    def record_failure(self, service_id: str):
        circuit = self._get_circuit(service_id)
        circuit["failures"] += 1
        circuit["last_failure"] = time.time()
        if circuit["failures"] >= self.failure_threshold:
            circuit["state"] = "open"

    def get_stats(self, service_id: str) -> dict[str, Any]:
        circuit = self._get_circuit(service_id)
        return {
            "state": circuit["state"],
            "failures": circuit["failures"],
            "threshold": self.failure_threshold,
        }


class ResilientHTTPClient:
    def __init__(self, timeout: float = 30.0, circuit_breaker: CircuitBreaker | None = None):
        self.timeout = timeout
        self.circuit_breaker = circuit_breaker or get_circuit_breaker()
        self.client = httpx.AsyncClient(timeout=timeout)

    def is_service_available(self, service_id: str) -> bool:
        return self.circuit_breaker.is_available(service_id)

    @retry(stop=stop_after_attempt(3), wait=wait_exponential(multiplier=1, min=1, max=10))
    async def post(self, url: str, json: dict, service_id: str | None = None, **kwargs) -> httpx.Response:
        if service_id and not self.circuit_breaker.is_available(service_id):
            raise CircuitOpenError(f"Circuit open for {service_id}")

        try:
            response = await self.client.post(url, json=json, **kwargs)
            if service_id:
                if response.status_code < 500:
                    self.circuit_breaker.record_success(service_id)
                else:
                    self.circuit_breaker.record_failure(service_id)
            return response
        except Exception as e:
            if service_id:
                self.circuit_breaker.record_failure(service_id)
            raise


_circuit_breaker: CircuitBreaker | None = None


def get_circuit_breaker() -> CircuitBreaker:
    global _circuit_breaker
    if _circuit_breaker is None:
        _circuit_breaker = CircuitBreaker()
    return _circuit_breaker


def get_resilient_client(timeout: float = 30.0) -> ResilientHTTPClient:
    return ResilientHTTPClient(timeout=timeout)
