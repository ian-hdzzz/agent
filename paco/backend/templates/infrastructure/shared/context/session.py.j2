import json
import logging
from datetime import datetime
from typing import Any

import redis.asyncio as redis

logger = logging.getLogger(__name__)


class Session:
    def __init__(self, conversation_id: str, contact_id: str | None = None):
        self.conversation_id = conversation_id
        self.contact_id = contact_id
        self.shared_data: dict[str, Any] = {}
        self.agent_visits: list[dict] = []
        self.created_at = datetime.utcnow().isoformat()

    def get_shared(self, key: str, default: Any = None) -> Any:
        return self.shared_data.get(key, default)

    def set_shared(self, key: str, value: Any):
        self.shared_data[key] = value

    def record_agent_visit(self, agent_id: str):
        self.agent_visits.append({
            "agent_id": agent_id,
            "timestamp": datetime.utcnow().isoformat(),
        })

    def to_dict(self) -> dict:
        return {
            "conversation_id": self.conversation_id,
            "contact_id": self.contact_id,
            "shared_data": self.shared_data,
            "agent_visits": self.agent_visits,
            "created_at": self.created_at,
        }

    @classmethod
    def from_dict(cls, data: dict) -> "Session":
        session = cls(data["conversation_id"], data.get("contact_id"))
        session.shared_data = data.get("shared_data", {})
        session.agent_visits = data.get("agent_visits", [])
        session.created_at = data.get("created_at", datetime.utcnow().isoformat())
        return session


class SessionStore:
    def __init__(self, redis_url: str = "redis://localhost:6379"):
        self.redis_url = redis_url
        self.redis: redis.Redis | None = None
        self.prefix = "session:"
        self.ttl = 3600

    async def connect(self):
        self.redis = redis.from_url(self.redis_url)
        logger.info("Session store connected")

    async def disconnect(self):
        if self.redis:
            await self.redis.close()

    async def get_or_create(self, conversation_id: str, contact_id: str | None = None) -> Session:
        if self.redis:
            data = await self.redis.get(f"{self.prefix}{conversation_id}")
            if data:
                return Session.from_dict(json.loads(data))
        session = Session(conversation_id, contact_id)
        await self.update(session)
        return session

    async def update(self, session: Session):
        if self.redis:
            await self.redis.setex(
                f"{self.prefix}{session.conversation_id}",
                self.ttl,
                json.dumps(session.to_dict()),
            )


_session_store: SessionStore | None = None


def get_session_store() -> SessionStore:
    global _session_store
    if _session_store is None:
        import os
        _session_store = SessionStore(os.getenv("REDIS_URL", "redis://localhost:6379"))
    return _session_store
