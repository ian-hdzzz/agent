# {{ infra.display_name or infra.name }} - Environment Variables
# Generated by PACO Infrastructure Manager

# API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# Logging
LOG_LEVEL=INFO
{% for key, value in (infra.env_config or {}).items() %}

# Custom: {{ key }}
{{ key }}={{ value }}
{% endfor %}
{% if lightning.enabled %}

# Agent Lightning
OTLP_ENDPOINT=
LIGHTNING_STORE_PORT={{ lightning.store_server_port | default(4318) }}
{% endif %}
{% if infra_type == "hive" %}

# Hive Coordinator
COORDINATOR_MODEL={{ coordinator.coordinator_model | default('claude-sonnet-4-5-20250929') }}
MAX_CONCURRENT_TASKS={{ coordinator.max_concurrent_tasks | default(5) }}
TASK_TIMEOUT={{ coordinator.task_timeout | default(300) }}
{% endif %}
