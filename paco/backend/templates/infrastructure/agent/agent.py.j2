import logging
import operator
from typing import Annotated, Any, Literal, TypedDict

from langchain_anthropic import ChatAnthropic
from langchain_core.messages import AIMessage, BaseMessage, HumanMessage, SystemMessage
from langgraph.graph import END, StateGraph
from langgraph.prebuilt import ToolNode

from .config import get_settings
from .prompts import get_system_prompt
from .tools import get_tools
{% if lightning.enabled %}
from agentlightning.agent import emit_annotation, emit_message, operation
{% endif %}

logger = logging.getLogger(__name__)
settings = get_settings()


class AgentState(TypedDict):
    messages: Annotated[list[BaseMessage], operator.add]
    task_type: str | None
    subtask_results: dict[str, Any]
    current_subtask: str | None
    contract_number: str | None
    user_data: dict[str, Any]
    metadata: dict[str, Any]


AGENT_CONFIG = {
    "id": "{{ agent.agent_id_slug }}",
    "name": "{{ agent.display_name or agent.agent_id_slug }}",
    "category_code": "{{ agent.category_code }}",
    "task_types": {{ agent.task_types | tojson }},
    "requires_contract": False,
}


def get_llm() -> ChatAnthropic:
    return ChatAnthropic(
        model=settings.model,
        api_key=settings.anthropic_api_key,
        max_tokens=settings.max_tokens,
        temperature=settings.temperature,
    )


def classify_task(state: AgentState) -> dict[str, Any]:
    messages = state["messages"]
    if not messages:
        return {"task_type": "general_inquiry"}

    last_message = messages[-1].content if messages else ""
    task_type = "general_inquiry"
    lower_message = last_message.lower() if isinstance(last_message, str) else ""

    if any(word in lower_message for word in ["ticket", "report", "complaint", "request"]):
        task_type = "create_ticket"
    elif any(word in lower_message for word in ["status", "check", "follow", "folio"]):
        task_type = "check_status"

    return {"task_type": task_type, "current_subtask": None}


def route_to_handler(state: AgentState) -> str:
    task_type = state.get("task_type", "general_inquiry")
    handler_map = {
{% for tt in agent.task_types %}
        "{{ tt }}": "handle_{{ tt }}",
{% endfor %}
    }
    return handler_map.get(task_type, "handle_{{ agent.task_types[0] if agent.task_types else 'general_inquiry' }}")


{% for tt in agent.task_types %}
async def handle_{{ tt }}(state: AgentState) -> dict[str, Any]:
    llm = get_llm()
    tools = get_tools()
    llm_with_tools = llm.bind_tools(tools) if tools else llm
    system_prompt = get_system_prompt("{{ tt }}")
    messages = [SystemMessage(content=system_prompt)] + state["messages"]
    response = await llm_with_tools.ainvoke(messages)
    return {
        "messages": [response],
        "subtask_results": {**state.get("subtask_results", {}), "{{ tt }}": {"status": "completed"}},
    }


{% endfor %}
def should_continue(state: AgentState) -> Literal["tools", "respond"]:
    messages = state.get("messages", [])
    if not messages:
        return "respond"
    last_message = messages[-1]
    if isinstance(last_message, AIMessage) and last_message.tool_calls:
        return "tools"
    return "respond"


def generate_response(state: AgentState) -> dict[str, Any]:
    return {}


def build_agent_graph() -> StateGraph:
    graph = StateGraph(AgentState)

    graph.add_node("classify", classify_task)
{% for tt in agent.task_types %}
    graph.add_node("handle_{{ tt }}", handle_{{ tt }})
{% endfor %}
    graph.add_node("tools", ToolNode(get_tools()))
    graph.add_node("respond", generate_response)

    graph.set_entry_point("classify")

    graph.add_conditional_edges(
        "classify",
        route_to_handler,
        {
{% for tt in agent.task_types %}
            "handle_{{ tt }}": "handle_{{ tt }}",
{% endfor %}
        },
    )

{% for tt in agent.task_types %}
    graph.add_conditional_edges("handle_{{ tt }}", should_continue, {"tools": "tools", "respond": "respond"})
{% endfor %}

    graph.add_edge("tools", "respond")
    graph.add_edge("respond", END)

    return graph


class Agent:
    def __init__(self):
        self.graph = build_agent_graph()
        self.app = self.graph.compile()
        self.config = AGENT_CONFIG

    async def run(self, message: str, conversation_history=None, metadata=None) -> dict[str, Any]:
{% if lightning.enabled %}
        try:
            emit_message("user", message, attributes={"agent_id": self.config["id"]})
        except Exception:
            pass
{% endif %}
        messages = list(conversation_history or [])
        messages.append(HumanMessage(content=message))

        initial_state: AgentState = {
            "messages": messages,
            "task_type": None,
            "subtask_results": {},
            "current_subtask": None,
            "contract_number": metadata.get("contract_number") if metadata else None,
            "user_data": metadata.get("user_data", {}) if metadata else {},
            "metadata": metadata or {},
        }

        try:
            result = await self.app.ainvoke(initial_state)
            response_messages = result.get("messages", [])
            last_message = response_messages[-1] if response_messages else None

            response_text = ""
            if last_message:
                if isinstance(last_message.content, str):
                    response_text = last_message.content
                elif isinstance(last_message.content, list):
                    response_text = " ".join(
                        block.get("text", "") for block in last_message.content
                        if isinstance(block, dict) and block.get("type") == "text"
                    )

{% if lightning.enabled %}
            try:
                emit_message("assistant", response_text, attributes={"agent_id": self.config["id"]})
                emit_annotation("task_type", result.get("task_type", "unknown"), attributes={"agent_id": self.config["id"]})
            except Exception:
                pass
{% endif %}
            return {
                "response": response_text,
                "messages": response_messages,
                "task_type": result.get("task_type"),
                "subtask_results": result.get("subtask_results", {}),
                "agent_id": self.config["id"],
            }
        except Exception as e:
            logger.error(f"Agent error: {e}")
            return {"response": "Sorry, I had a problem. Please try again.", "error": str(e), "agent_id": self.config["id"]}

    def get_health(self) -> dict[str, Any]:
        return {
            "status": "healthy",
            "agent_id": self.config["id"],
            "agent_name": self.config["name"],
            "category_code": self.config["category_code"],
            "task_types": self.config["task_types"],
        }


_agent: Agent | None = None


def get_agent() -> Agent:
    global _agent
    if _agent is None:
        _agent = Agent()
    return _agent
