FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

COPY agents/{{ agent.agent_id_slug }}/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY shared/ ./shared/
COPY agents/{{ agent.agent_id_slug }}/ ./agents/{{ agent.agent_id_slug }}/

EXPOSE 8000

CMD ["uvicorn", "agents.{{ agent.agent_id_slug }}.main:app", "--host", "0.0.0.0", "--port", "8000"]
