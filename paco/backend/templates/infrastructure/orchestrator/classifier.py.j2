import json
import logging
import re
from typing import Any, Literal

from anthropic import Anthropic

from .config import get_settings

logger = logging.getLogger(__name__)
settings = get_settings()

CategoryCode = Literal[
{% for agent in agents %}
    "{{ agent.category_code }}",
{% endfor %}
    "EXIT",
]

{% if orchestrator.classification_prompt %}
CLASSIFICATION_PROMPT = """{{ orchestrator.classification_prompt }}"""
{% else %}
CLASSIFICATION_PROMPT = """You are an intent classifier. Categorize each user message into ONE of these categories:

{% for agent in agents %}
{{ loop.index }}. {{ agent.category_code }} - {{ agent.display_name or agent.agent_id_slug }}: {{ agent.description or 'General inquiries' }}
{% endfor %}
{{ agents | length + 1 }}. EXIT - User wants to end the conversation

Respond ONLY with the category code. No explanations."""
{% endif %}


KEYWORD_MAP: dict[str, list[str]] = {
{% for agent in agents %}
    "{{ agent.category_code }}": {{ agent.keywords | tojson }},
{% endfor %}
    "EXIT": ["bye", "goodbye", "thanks", "thank you", "exit", "quit"],
}


def keyword_classify(message: str) -> CategoryCode | None:
    lower_message = message.lower()
    matches: dict[str, int] = {}

    for category, keywords in KEYWORD_MAP.items():
        score = sum(1 for kw in keywords if kw in lower_message)
        if score > 0:
            matches[category] = score

    if not matches:
        return None

    sorted_matches = sorted(matches.items(), key=lambda x: x[1], reverse=True)

    if len(sorted_matches) == 1:
        return sorted_matches[0][0]

    if sorted_matches[0][1] > sorted_matches[1][1] * 2:
        return sorted_matches[0][0]

    return None


async def llm_classify(message: str, context: str | None = None) -> dict[str, Any]:
    client = Anthropic(api_key=settings.anthropic_api_key)
    prompt = CLASSIFICATION_PROMPT
    if context:
        prompt = f"Conversation history:\n{context}\n\n{prompt}"

    try:
        response = client.messages.create(
            model=settings.model,
            max_tokens=10,
            temperature=settings.classification_temperature,
            system=prompt,
            messages=[{"role": "user", "content": message}],
        )

        content = response.content[0].text.strip().upper()

        valid_categories = [
{% for agent in agents %}
            "{{ agent.category_code }}",
{% endfor %}
            "EXIT",
        ]

        fallback = "{{ orchestrator.fallback_agent or agents[0].category_code }}"
        category = fallback
        for cat in valid_categories:
            if cat in content:
                category = cat
                break

        return {
            "category": category,
            "raw_response": content,
            "confidence": 0.9 if category != fallback else 0.5,
            "method": "llm",
        }

    except Exception as e:
        logger.error(f"LLM classification error: {e}")
        return {
            "category": "{{ orchestrator.fallback_agent or agents[0].category_code }}",
            "error": str(e),
            "confidence": 0.3,
            "method": "fallback",
        }


async def classify_intent(
    message: str,
    context: str | None = None,
    use_keywords: bool = True,
) -> dict[str, Any]:
    if use_keywords:
        keyword_result = keyword_classify(message)
        if keyword_result:
            return {
                "category": keyword_result,
                "confidence": 0.85,
                "method": "keyword",
            }

    return await llm_classify(message, context)


def extract_contract_number(message: str) -> str | None:
    match = re.search(r"\b(\d{6,10})\b", message)
    return match.group(1) if match else None


def get_category_description(category: str) -> str:
    descriptions = {
{% for agent in agents %}
        "{{ agent.category_code }}": "{{ agent.display_name or agent.agent_id_slug }}",
{% endfor %}
        "EXIT": "End of conversation",
    }
    return descriptions.get(category, category)


def is_ambiguous_message(message: str) -> bool:
    short_responses = {
        "yes", "no", "ok", "sure", "thanks", "okay", "fine",
        "got it", "alright", "right", "yep", "nope",
    }
    cleaned = message.lower().strip().rstrip(".,!?")
    return len(cleaned) < 15 or cleaned in short_responses
