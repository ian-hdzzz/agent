"""
{{ infra.display_name or infra.name }} - Orchestrator Configuration
Generated by PACO Infrastructure Manager
"""

import os
from functools import lru_cache

from pydantic_settings import BaseSettings


class OrchestratorSettings(BaseSettings):
    anthropic_api_key: str = os.getenv("ANTHROPIC_API_KEY", "")
    database_url: str = os.getenv("DATABASE_URL", "postgresql+asyncpg://postgres:postgres@localhost:5432/{{ infra.db_name or infra.name }}")
    redis_url: str = os.getenv("REDIS_URL", "redis://localhost:6379")
    log_level: str = os.getenv("LOG_LEVEL", "INFO")

    host: str = "0.0.0.0"
    port: int = 8000

    model: str = "{{ orchestrator.classification_model }}"
    classification_temperature: float = {{ orchestrator.classification_temperature }}

{% for agent in agents %}
    agent_{{ agent.category_code | lower }}_url: str = os.getenv("AGENT_{{ agent.category_code }}_URL", "http://localhost:{{ infra.port_range_start + loop.index }}")
{% endfor %}

    agent_timeout: float = {{ orchestrator.agent_timeout }}

    class Config:
        env_file = ".env"
        case_sensitive = False


@lru_cache()
def get_settings() -> OrchestratorSettings:
    return OrchestratorSettings()


def get_agent_registry() -> dict[str, dict[str, str]]:
    settings = get_settings()
    return {
{% for agent in agents %}
        "{{ agent.category_code }}": {
            "id": "{{ agent.agent_id_slug }}",
            "name": "{{ agent.display_name or agent.agent_id_slug }}",
            "url": settings.agent_{{ agent.category_code | lower }}_url,
            "description": "{{ agent.description or '' }}",
        },
{% endfor %}
    }
