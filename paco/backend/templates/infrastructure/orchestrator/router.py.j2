logger = logging.getLogger(__name__)
settings = get_settings()

FALLBACK_AGENT_CATEGORY = "{{ orchestrator.fallback_agent or agents[0].category_code }}"


class OrchestratorState(TypedDict):
    messages: Annotated[list[BaseMessage], operator.add]
    detected_category: CategoryCode | None
    agent_response: str | None
    agent_id: str | None
    contract_number: str | None
    task_type: str | None
    metadata: dict[str, Any]
    error: str | None


async def classify_intent_node(state: OrchestratorState) -> dict[str, Any]:
    messages = state.get("messages", [])
    metadata = state.get("metadata", {})

    if not messages:
        return {"detected_category": FALLBACK_AGENT_CATEGORY, "error": "No message provided"}

    last_message = None
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            last_message = msg.content
            break

    if not last_message:
        return {"detected_category": FALLBACK_AGENT_CATEGORY, "error": "No user message found"}

    last_category = metadata.get("last_category")
    if last_category and is_ambiguous_message(last_message):
        return {
            "detected_category": last_category,
            "contract_number": state.get("contract_number"),
        }

    context_messages = []
    for msg in messages[-6:]:
        role = "User" if isinstance(msg, HumanMessage) else "Assistant"
        context_messages.append(f"{role}: {msg.content}")
    context = "\n".join(context_messages)

    result = await classify_intent(last_message, context)
    contract_number = extract_contract_number(last_message)

{% if lightning.enabled %}
    try:
        emit_message("user", last_message, attributes={"node": "classify"})
        emit_annotation("classification", result["category"], attributes={
            "method": result.get("method", "unknown"),
            "confidence": str(result.get("confidence", 0.0)),
        })
    except Exception:
        pass
{% endif %}

    return {
        "detected_category": result["category"],
        "contract_number": contract_number or state.get("contract_number"),
    }


def route_to_agent(state: OrchestratorState) -> str:
    category = state.get("detected_category", FALLBACK_AGENT_CATEGORY)
    if category == "EXIT":
        return "handle_exit"
    return "call_agent"


async def call_fallback_agent(state: OrchestratorState, original_agent_id: str, fallback_reason: str) -> dict[str, Any]:
    registry = get_agent_registry()
    fallback_info = registry[FALLBACK_AGENT_CATEGORY]
    fallback_url = fallback_info["url"]
    fallback_id = fallback_info["id"]

    messages = state.get("messages", [])
    last_message = ""
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            last_message = msg.content
            break

    logger.warning(f"Falling back to {fallback_id} from {original_agent_id}: {fallback_reason}")

    try:
        client = get_resilient_client(timeout=settings.agent_timeout)
        response = await client.post(
            f"{fallback_url}/query",
            json={
                "message": last_message,
                "conversation_id": state.get("metadata", {}).get("conversation_id"),
                "metadata": {
                    "contract_number": state.get("contract_number"),
                    "category": FALLBACK_AGENT_CATEGORY,
                    "is_fallback": True,
                    **state.get("metadata", {}),
                },
            },
            service_id=fallback_id,
        )
        data = response.json()
        agent_response = data.get("response", "")
        return {
            "agent_response": agent_response,
            "agent_id": fallback_id,
            "messages": [AIMessage(content=agent_response)],
        }
    except Exception as e:
        logger.error(f"Fallback agent {fallback_id} also failed: {e}")
        return {"error": f"Both primary and fallback agents failed: {str(e)}", "agent_id": fallback_id}


async def call_agent(state: OrchestratorState) -> dict[str, Any]:
    category = state.get("detected_category", FALLBACK_AGENT_CATEGORY)
    registry = get_agent_registry()

    agent_info = registry.get(category, registry[FALLBACK_AGENT_CATEGORY])
    agent_url = agent_info["url"]
    agent_id = agent_info["id"]

    messages = state.get("messages", [])
    last_message = ""
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            last_message = msg.content
            break

    client = get_resilient_client(timeout=settings.agent_timeout)

    if not client.is_service_available(agent_id):
        return await call_fallback_agent(state, agent_id, "Circuit breaker open")

    try:
        response = await client.post(
            f"{agent_url}/query",
            json={
                "message": last_message,
                "conversation_id": state.get("metadata", {}).get("conversation_id"),
                "metadata": {
                    "contract_number": state.get("contract_number"),
                    "category": category,
                    **state.get("metadata", {}),
                },
            },
            service_id=agent_id,
        )

        if response.status_code == 200:
            data = response.json()
            agent_response = data.get("response", "")
{% if lightning.enabled %}
            try:
                emit_message("assistant", agent_response, attributes={"agent_id": agent_id, "category": category})
            except Exception:
                pass
{% endif %}
            return {
                "agent_response": agent_response,
                "agent_id": agent_id,
                "task_type": data.get("task_type"),
                "messages": [AIMessage(content=agent_response)],
            }
        elif response.status_code >= 500:
            return await call_fallback_agent(state, agent_id, f"Agent returned {response.status_code}")
        else:
            return {"error": f"Agent returned status {response.status_code}", "agent_id": agent_id}

    except CircuitOpenError:
        return await call_fallback_agent(state, agent_id, "Circuit opened during request")
    except RetryError as e:
        return await call_fallback_agent(state, agent_id, f"All retries exhausted: {e}")
    except httpx.TimeoutException:
        return await call_fallback_agent(state, agent_id, "Agent timed out")
    except Exception as e:
        return await call_fallback_agent(state, agent_id, str(e))


def handle_exit(state: OrchestratorState) -> dict[str, Any]:
    farewell = "Thank you for using our service. Have a great day!"
    return {"agent_response": farewell, "agent_id": "orchestrator", "messages": [AIMessage(content=farewell)]}


def handle_error(state: OrchestratorState) -> dict[str, Any]:
    response = "Sorry, I had a problem processing your request. Please try again."
    return {"agent_response": response, "messages": [AIMessage(content=response)]}


def should_handle_error(state: OrchestratorState) -> str:
    return "handle_error" if state.get("error") else "end"


def build_orchestrator_graph() -> StateGraph:
    graph = StateGraph(OrchestratorState)

    graph.add_node("classify", classify_intent_node)
    graph.add_node("call_agent", call_agent)
    graph.add_node("handle_exit", handle_exit)
    graph.add_node("handle_error", handle_error)

    graph.set_entry_point("classify")

    graph.add_conditional_edges("classify", route_to_agent, {"call_agent": "call_agent", "handle_exit": "handle_exit"})
    graph.add_conditional_edges("call_agent", should_handle_error, {"handle_error": "handle_error", "end": END})
    graph.add_edge("handle_exit", END)
    graph.add_edge("handle_error", END)

    return graph


class Orchestrator:
    def __init__(self):
        self.graph = build_orchestrator_graph()
        self.app = self.graph.compile()

    async def route(self, message: str, conversation_history=None, metadata=None) -> dict[str, Any]:
        messages = list(conversation_history or [])
        messages.append(HumanMessage(content=message))

        initial_state: OrchestratorState = {
            "messages": messages,
            "detected_category": None,
            "agent_response": None,
            "agent_id": None,
            "contract_number": metadata.get("contract_number") if metadata else None,
            "task_type": None,
            "metadata": metadata or {},
            "error": None,
        }

        try:
            result = await self.app.ainvoke(initial_state)
{% if lightning.enabled and lightning.auto_rewards %}
            try:
                evaluator = get_reward_evaluator()
                evaluator.evaluate_user_message(
                    message,
                    conversation_id=metadata.get("conversation_id") if metadata else None,
                )
            except Exception:
                pass
{% endif %}
            return {
                "response": result.get("agent_response", ""),
                "category": result.get("detected_category"),
                "category_description": get_category_description(result.get("detected_category", FALLBACK_AGENT_CATEGORY)),
                "agent_id": result.get("agent_id"),
                "contract_number": result.get("contract_number"),
                "task_type": result.get("task_type"),
                "error": result.get("error"),
            }
        except Exception as e:
            logger.error(f"Orchestrator error: {e}")
            return {"response": "Sorry, I had a problem.", "category": FALLBACK_AGENT_CATEGORY, "error": str(e)}

    def get_health(self) -> dict[str, Any]:
        registry = get_agent_registry()
        circuit_breaker = get_circuit_breaker()
        agent_status = {}
        for category, info in registry.items():
            agent_status[info["id"]] = circuit_breaker.get_stats(info["id"])
        return {
            "status": "healthy",
            "service": "orchestrator",
            "agents": list(registry.keys()),
            "agent_count": len(registry),
            "circuit_status": agent_status,
        }


_orchestrator: Orchestrator | None = None


def get_orchestrator() -> Orchestrator:
    global _orchestrator
    if _orchestrator is None:
        _orchestrator = Orchestrator()
    return _orchestrator
