# ============================================
# {{ infra.display_name or infra.name }} - Multi-Agent Orchestration
# Generated by PACO Infrastructure Manager
# ============================================
#
# Usage:
#   docker-compose up --build        # Build and start all services
#   docker-compose up --build -d     # Build and start in background
#   docker-compose logs -f           # Follow logs
#   docker-compose down              # Stop and remove

services:
{% if infra_type == "hive" %}
  # ===== HIVE COORDINATOR =====
  coordinator:
    build:
      context: .
      dockerfile: coordinator/Dockerfile
    container_name: {{ infra.name }}-coordinator
    restart: unless-stopped
    ports:
      - "{{ infra.port_range_start }}:8000"
    environment:
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
      - REDIS_URL=redis://redis:6379
      - DATABASE_URL=postgres://postgres:postgres@postgres:5432/{{ infra.db_name or infra.name }}
      - LOG_LEVEL=${LOG_LEVEL:-INFO}
      - COORDINATOR_MODEL=${COORDINATOR_MODEL:-{{ coordinator.coordinator_model | default('claude-sonnet-4-5-20250929') }}}
      - MAX_CONCURRENT_TASKS=${MAX_CONCURRENT_TASKS:-{{ coordinator.max_concurrent_tasks | default(5) }}}
      - TASK_TIMEOUT=${TASK_TIMEOUT:-{{ coordinator.task_timeout | default(300) }}}
{% if lightning.enabled %}
      - OTLP_ENDPOINT=${OTLP_ENDPOINT:-}
      - LIGHTNING_STORE_PORT=${LIGHTNING_STORE_PORT:-{{ lightning.store_server_port | default(4318) }}}
{% endif %}
{% for agent in agents %}
      - WORKER_{{ agent.category_code }}_URL=http://worker-{{ agent.agent_id_slug }}:8000
{% endfor %}
    depends_on:
      - redis
      - postgres
    networks:
      - {{ infra.name }}-network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  # ===== HIVE WORKERS =====
{% for agent in agents %}
  worker-{{ agent.agent_id_slug }}:
    build:
      context: .
      dockerfile: hive_worker/{{ agent.agent_id_slug }}/Dockerfile
    container_name: {{ infra.name }}-worker-{{ agent.agent_id_slug }}
    restart: unless-stopped
    ports:
      - "{{ infra.port_range_start + loop.index }}:8000"
    environment:
      - AGENT_SLUG={{ agent.agent_id_slug }}
      - COORDINATOR_URL=http://coordinator:8000
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
      - DATABASE_URL=postgres://postgres:postgres@postgres:5432/{{ infra.db_name or infra.name }}
      - REDIS_URL=redis://redis:6379
      - LOG_LEVEL=${LOG_LEVEL:-INFO}
{% if lightning.enabled %}
      - OTLP_ENDPOINT=${OTLP_ENDPOINT:-}
{% endif %}
    depends_on:
      - coordinator
      - redis
      - postgres
    networks:
      - {{ infra.name }}-network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
{% endfor %}
{% else %}
  # ===== TIER 0: ORCHESTRATOR =====
  orchestrator:
    build:
      context: .
      dockerfile: orchestrator/Dockerfile
    container_name: {{ infra.name }}-orchestrator
    restart: unless-stopped
    ports:
      - "{{ infra.port_range_start }}:8000"
    environment:
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
      - REDIS_URL=redis://redis:6379
      - DATABASE_URL=postgres://postgres:postgres@postgres:5432/{{ infra.db_name or infra.name }}
      - LOG_LEVEL=${LOG_LEVEL:-INFO}
{% if lightning.enabled %}
      - OTLP_ENDPOINT=${OTLP_ENDPOINT:-}
      - LIGHTNING_STORE_PORT=${LIGHTNING_STORE_PORT:-{{ lightning.store_server_port | default(4318) }}}
{% endif %}
{% for agent in agents %}
      - AGENT_{{ agent.category_code }}_URL=http://agent-{{ agent.agent_id_slug }}:8000
{% endfor %}
    depends_on:
      - redis
      - postgres
    networks:
      - {{ infra.name }}-network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  # ===== TIER 1: SPECIALIST AGENTS =====
{% for agent in agents %}

  # Agent {{ loop.index }}: {{ agent.display_name or agent.agent_id_slug }}
  agent-{{ agent.agent_id_slug }}:
    build:
      context: .
      dockerfile: agents/{{ agent.agent_id_slug }}/Dockerfile
    container_name: {{ infra.name }}-agent-{{ agent.agent_id_slug }}
    restart: unless-stopped
    ports:
      - "{{ infra.port_range_start + loop.index }}:8000"
    environment:
      - AGENT_ID={{ agent.agent_id_slug }}
      - AGENT_NAME={{ agent.display_name or agent.agent_id_slug }}
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
      - DATABASE_URL=postgres://postgres:postgres@postgres:5432/{{ infra.db_name or infra.name }}
      - REDIS_URL=redis://redis:6379
      - LOG_LEVEL=${LOG_LEVEL:-INFO}
{% if lightning.enabled %}
      - OTLP_ENDPOINT=${OTLP_ENDPOINT:-}
{% endif %}
    depends_on:
      - redis
      - postgres
    networks:
      - {{ infra.name }}-network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
{% endfor %}
{% endif %}

  # ===== SHARED SERVICES =====

  redis:
    image: redis:7-alpine
    container_name: {{ infra.name }}-redis
    restart: unless-stopped
    volumes:
      - redis_data:/data
    networks:
      - {{ infra.name }}-network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 3

  postgres:
    image: postgres:15-alpine
    container_name: {{ infra.name }}-postgres
    restart: unless-stopped
    environment:
      - POSTGRES_DB={{ infra.db_name or infra.name }}
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=postgres
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./shared/db/init.sql:/docker-entrypoint-initdb.d/init.sql:ro
    networks:
      - {{ infra.name }}-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d {{ infra.db_name or infra.name }}"]
      interval: 10s
      timeout: 5s
      retries: 3

networks:
  {{ infra.name }}-network:
    driver: bridge

volumes:
  postgres_data:
  redis_data:
