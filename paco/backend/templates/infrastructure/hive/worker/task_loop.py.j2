"""
{{ infra.display_name or infra.name }} - Worker Task Loop ({{ agent.display_name or agent.agent_id_slug }})
Generated by PACO Infrastructure Manager

Background loop that polls for tasks and executes them.
"""

import asyncio
import logging
from typing import Any

import httpx

from .config import get_settings

logger = logging.getLogger(__name__)

settings = get_settings()


class TaskLoop:
    """Background task execution loop for a hive worker."""

    def __init__(self):
        self._running = False
        self._http: httpx.AsyncClient | None = None

    async def run(self) -> None:
        """Main loop: poll coordinator for tasks, execute them, report back."""
        self._running = True
        self._http = httpx.AsyncClient(timeout=httpx.Timeout(60.0))
        logger.info(f"Task loop started for worker {settings.agent_slug}")

        while self._running:
            try:
                await asyncio.sleep(settings.poll_interval)
            except asyncio.CancelledError:
                break

        if self._http:
            await self._http.aclose()
        logger.info(f"Task loop stopped for worker {settings.agent_slug}")

    def stop(self) -> None:
        """Signal the loop to stop."""
        self._running = False

    async def report_completion(
        self,
        task_id: str,
        result: dict[str, Any],
    ) -> None:
        """Report task completion to the coordinator."""
        if not self._http:
            self._http = httpx.AsyncClient(timeout=httpx.Timeout(30.0))

        try:
            response = await self._http.post(
                f"{settings.coordinator_url}/tasks/{task_id}/complete",
                json=result,
            )
            response.raise_for_status()
            logger.info(f"Reported completion for task {task_id}")
        except httpx.HTTPError as e:
            logger.error(f"Failed to report completion for task {task_id}: {e}")

    async def report_failure(
        self,
        task_id: str,
        error: str,
    ) -> None:
        """Report task failure to the coordinator."""
        if not self._http:
            self._http = httpx.AsyncClient(timeout=httpx.Timeout(30.0))

        try:
            response = await self._http.post(
                f"{settings.coordinator_url}/tasks/{task_id}/fail",
                json={"message": error},
            )
            response.raise_for_status()
            logger.info(f"Reported failure for task {task_id}")
        except httpx.HTTPError as e:
            logger.error(f"Failed to report failure for task {task_id}: {e}")


_task_loop: TaskLoop | None = None


def get_task_loop() -> TaskLoop:
    global _task_loop
    if _task_loop is None:
        _task_loop = TaskLoop()
    return _task_loop
