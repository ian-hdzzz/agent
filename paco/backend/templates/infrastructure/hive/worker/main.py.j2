@app.post("/execute", response_model=ExecuteResponse)
async def execute_task(request: ExecuteRequest):
    """Receive a task from the coordinator and execute it."""
    try:
        agent = get_agent()

        # Run the agent with the task description as the message
        task_message = f"{request.subject}\n\n{request.description}"
        result = await agent.run(
            message=task_message,
            metadata={
                "task_id": request.task_id,
                "execution_id": request.execution_id,
                "priority": request.priority,
            },
        )

        response_text = result.get("response", "")

        # Report completion to coordinator
        task_loop = get_task_loop()
        await task_loop.report_completion(
            task_id=request.task_id,
            result={"response": response_text},
        )

        return ExecuteResponse(
            task_id=request.task_id,
            status="completed",
            response=response_text,
        )

    except Exception as e:
        logger.error(f"Task execution error: {e}")
        # Report failure to coordinator
        task_loop = get_task_loop()
        await task_loop.report_failure(
            task_id=request.task_id,
            error=str(e),
        )
        return ExecuteResponse(
            task_id=request.task_id,
            status="failed",
            response="",
            error=str(e),
        )


