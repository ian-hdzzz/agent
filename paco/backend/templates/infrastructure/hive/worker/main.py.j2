@asynccontextmanager
async def lifespan(app: FastAPI):
    logger.info(f"Starting hive worker: {settings.agent_slug}")
    agent = get_agent()
    logger.info(f"Agent initialized: {agent.config['name']}")

    # Start background task loop
    task_loop = get_task_loop()
    loop_task = asyncio.create_task(task_loop.run())

    yield

    logger.info(f"Shutting down worker: {settings.agent_slug}")
    task_loop.stop()
    loop_task.cancel()
    try:
        await loop_task
    except asyncio.CancelledError:
        pass


