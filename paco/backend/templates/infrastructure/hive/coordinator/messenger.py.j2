"""
{{ infra.display_name or infra.name }} - Inter-Agent Messenger
Generated by PACO Infrastructure Manager

Handles communication between coordinator and worker agents.
"""

import json
import logging
import time
import uuid
from typing import Any

import httpx
import redis.asyncio as redis

from .config import get_settings, get_worker_registry

logger = logging.getLogger(__name__)

settings = get_settings()


class Messenger:
    """Handles messaging between coordinator and workers."""

    def __init__(self):
        self._redis: redis.Redis | None = None
        self._http: httpx.AsyncClient | None = None

    async def connect(self) -> None:
        self._redis = redis.from_url(settings.redis_url, decode_responses=True)
        self._http = httpx.AsyncClient(timeout=httpx.Timeout(settings.task_timeout))

    async def disconnect(self) -> None:
        if self._redis:
            await self._redis.close()
        if self._http:
            await self._http.aclose()

    async def send_task(
        self,
        worker_url: str,
        task: dict[str, Any],
        execution_id: str,
    ) -> dict[str, Any] | None:
        """Send a task to a specific worker for execution."""
        message = {
            "id": str(uuid.uuid4()),
            "type": "task",
            "sender": "coordinator",
            "recipient": task["assigned_agent_slug"],
            "content": {
                "task_id": task["id"],
                "execution_id": execution_id,
                "subject": task["subject"],
                "description": task["description"],
                "priority": task.get("priority", 3),
            },
            "summary": f"Execute: {task['subject']}",
            "timestamp": time.time(),
        }

        # Store in Redis for audit trail
        if self._redis:
            await self._redis.lpush(
                f"messages:{execution_id}",
                json.dumps(message),
            )
            await self._redis.expire(f"messages:{execution_id}", 3600)

        # Send to worker via HTTP
        try:
            response = await self._http.post(
                f"{worker_url}/execute",
                json=message["content"],
            )
            response.raise_for_status()
            return response.json()
        except httpx.HTTPError as e:
            logger.error(f"Failed to send task to {worker_url}: {e}")
            return None

    async def send_message(
        self,
        recipient_slug: str,
        content: str,
        summary: str,
    ) -> None:
        """Send a direct message to a specific worker."""
        registry = get_worker_registry()
        worker = registry.get(recipient_slug)
        if not worker:
            logger.warning(f"Unknown worker: {recipient_slug}")
            return

        message = {
            "id": str(uuid.uuid4()),
            "type": "message",
            "sender": "coordinator",
            "recipient": recipient_slug,
            "content": content,
            "summary": summary,
            "timestamp": time.time(),
        }

        if self._redis:
            await self._redis.lpush(
                f"inbox:{recipient_slug}",
                json.dumps(message),
            )
            await self._redis.expire(f"inbox:{recipient_slug}", 3600)

    async def broadcast(self, content: str, summary: str) -> None:
        """Broadcast a message to all workers."""
        registry = get_worker_registry()
        for slug in registry:
            await self.send_message(slug, content, summary)

    async def send_shutdown_request(self, recipient_slug: str, reason: str = "") -> None:
        """Request a worker to shut down gracefully."""
        registry = get_worker_registry()
        worker = registry.get(recipient_slug)
        if not worker:
            return

        message = {
            "id": str(uuid.uuid4()),
            "type": "shutdown_request",
            "sender": "coordinator",
            "recipient": recipient_slug,
            "content": reason or "Coordinator requested shutdown",
            "timestamp": time.time(),
        }

        if self._redis:
            await self._redis.lpush(
                f"inbox:{recipient_slug}",
                json.dumps(message),
            )

    async def get_messages(self, recipient_slug: str, count: int = 10) -> list[dict[str, Any]]:
        """Retrieve messages from a worker's inbox."""
        if not self._redis:
            return []

        raw_messages = await self._redis.lrange(f"inbox:{recipient_slug}", 0, count - 1)
        return [json.loads(m) for m in raw_messages]


_messenger: Messenger | None = None


def get_messenger() -> Messenger:
    global _messenger
    if _messenger is None:
        _messenger = Messenger()
    return _messenger
