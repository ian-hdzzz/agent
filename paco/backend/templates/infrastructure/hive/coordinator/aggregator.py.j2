"""
{{ infra.display_name or infra.name }} - Result Aggregator
Generated by PACO Infrastructure Manager

Aggregates results from completed worker tasks into a final response.
"""

import logging
from typing import Any

import anthropic

from .config import get_settings

logger = logging.getLogger(__name__)

settings = get_settings()


async def aggregate_results(
    results: list[dict[str, Any]],
    original_message: str,
    strategy: str = "merge",
) -> str:
    """Aggregate task results into a final response.

    Strategies:
      - merge: Combine all results into a single response
      - summarize: Use LLM to create a coherent summary
      - first: Return the first completed result
    """
    if not results:
        return "No results were produced for your request."

    if strategy == "first":
        return _extract_response(results[0])

    if strategy == "merge":
        return _merge_results(results)

    if strategy == "summarize":
        return await _summarize_results(results, original_message)

    logger.warning(f"Unknown aggregation strategy: {strategy}, falling back to merge")
    return _merge_results(results)


def _extract_response(result: dict[str, Any]) -> str:
    """Extract response text from a task result."""
    task_result = result.get("result", {})
    if isinstance(task_result, dict):
        return task_result.get("response", str(task_result))
    return str(task_result)


def _merge_results(results: list[dict[str, Any]]) -> str:
    """Merge all results into a combined response."""
    parts = []
    for result in results:
        subject = result.get("subject", "Task")
        response = _extract_response(result)
        if response:
            parts.append(f"**{subject}**\n{response}")

    return "\n\n".join(parts) if parts else "Tasks completed but produced no output."


async def _summarize_results(
    results: list[dict[str, Any]],
    original_message: str,
) -> str:
    """Use LLM to create a coherent summary of all results."""
    client = anthropic.AsyncAnthropic(api_key=settings.anthropic_api_key)

    results_text = "\n\n".join(
        f"Task: {r.get('subject', 'Unknown')}\n"
        f"Agent: {r.get('assigned_agent_slug', 'unknown')}\n"
        f"Result: {_extract_response(r)}"
        for r in results
    )

    aggregation_prompt = settings.aggregation_prompt or (
        "You are a response aggregator. Given the original user request and "
        "results from multiple specialist agents, create a single coherent response "
        "that addresses the user's needs. Be concise and helpful."
    )

    try:
        response = await client.messages.create(
            model=settings.coordinator_model,
            max_tokens=2048,
            temperature=0.3,
            system=aggregation_prompt,
            messages=[
                {
                    "role": "user",
                    "content": (
                        f"Original request: {original_message}\n\n"
                        f"Agent results:\n{results_text}\n\n"
                        "Please provide a unified response."
                    ),
                },
            ],
        )
        return response.content[0].text
    except Exception as e:
        logger.error(f"Summarization error: {e}")
        return _merge_results(results)
