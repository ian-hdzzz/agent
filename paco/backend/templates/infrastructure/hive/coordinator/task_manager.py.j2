"""
{{ infra.display_name or infra.name }} - Task Manager
Generated by PACO Infrastructure Manager

Manages task lifecycle: creation, tracking, dependencies, and completion.
"""

import asyncio
import logging
import time
import uuid
from typing import Any

from .config import get_settings

logger = logging.getLogger(__name__)

settings = get_settings()


class TaskManager:
    """Manages tasks across an execution lifecycle."""

    def __init__(self):
        self._tasks: dict[str, dict[str, Any]] = {}
        self._executions: dict[str, list[str]] = {}
        self._completion_events: dict[str, asyncio.Event] = {}

    def create_tasks(
        self,
        execution_id: str,
        subtasks: list[dict[str, Any]],
    ) -> list[dict[str, Any]]:
        """Create tasks from decomposition results."""
        tasks = []
        subject_to_id: dict[str, str] = {}

        # First pass: create all tasks with IDs
        for subtask in subtasks:
            task_id = str(uuid.uuid4())
            subject_to_id[subtask["subject"]] = task_id

            task = {
                "id": task_id,
                "execution_id": execution_id,
                "subject": subtask["subject"],
                "description": subtask["description"],
                "assigned_agent_slug": subtask["assigned_agent_slug"],
                "priority": subtask.get("priority", 3),
                "status": "pending",
                "blocked_by": [],
                "blocks": [],
                "result": None,
                "error": None,
                "created_at": time.time(),
                "started_at": None,
                "completed_at": None,
            }
            self._tasks[task_id] = task
            tasks.append(task)

        # Second pass: resolve dependencies
        for subtask, task in zip(subtasks, tasks):
            for dep_subject in subtask.get("blocked_by", []):
                dep_id = subject_to_id.get(dep_subject)
                if dep_id:
                    task["blocked_by"].append(dep_id)
                    self._tasks[dep_id]["blocks"].append(task["id"])

        self._executions[execution_id] = [t["id"] for t in tasks]
        self._completion_events[execution_id] = asyncio.Event()

        return tasks

    def update_status(self, task_id: str, status: str) -> None:
        """Update task status."""
        if task_id not in self._tasks:
            logger.warning(f"Task {task_id} not found")
            return

        task = self._tasks[task_id]
        task["status"] = status
        if status == "in_progress":
            task["started_at"] = time.time()
        logger.info(f"Task {task_id} ({task['subject']}): {status}")

    def complete_task(self, task_id: str, result: dict[str, Any]) -> None:
        """Mark a task as completed with its result."""
        if task_id not in self._tasks:
            logger.warning(f"Task {task_id} not found")
            return

        task = self._tasks[task_id]
        task["status"] = "completed"
        task["result"] = result
        task["completed_at"] = time.time()
        logger.info(f"Task {task_id} ({task['subject']}): completed")

        # Check if execution is done
        execution_id = task["execution_id"]
        if self._is_execution_complete(execution_id):
            event = self._completion_events.get(execution_id)
            if event:
                event.set()

    def fail_task(self, task_id: str, error: str) -> None:
        """Mark a task as failed."""
        if task_id not in self._tasks:
            return

        task = self._tasks[task_id]
        task["status"] = "failed"
        task["error"] = error
        task["completed_at"] = time.time()
        logger.error(f"Task {task_id} ({task['subject']}): failed - {error}")

        # Cancel dependent tasks
        for blocked_id in task.get("blocks", []):
            if self._tasks.get(blocked_id, {}).get("status") == "pending":
                self._tasks[blocked_id]["status"] = "cancelled"
                self._tasks[blocked_id]["error"] = f"Dependency {task_id} failed"

        execution_id = task["execution_id"]
        if self._is_execution_complete(execution_id):
            event = self._completion_events.get(execution_id)
            if event:
                event.set()

    def get_unblocked_tasks(self, completed_task_id: str) -> list[dict[str, Any]]:
        """Get tasks that are now unblocked after a task completes."""
        completed_task = self._tasks.get(completed_task_id)
        if not completed_task:
            return []

        unblocked = []
        for blocked_id in completed_task.get("blocks", []):
            blocked_task = self._tasks.get(blocked_id)
            if not blocked_task or blocked_task["status"] != "pending":
                continue

            # Check if all dependencies are satisfied
            all_deps_done = all(
                self._tasks.get(dep_id, {}).get("status") == "completed"
                for dep_id in blocked_task["blocked_by"]
            )
            if all_deps_done:
                unblocked.append(blocked_task)

        return unblocked

    def claim_task(self, task_id: str, worker_id: str) -> bool:
        """Attempt to claim a task for a worker."""
        task = self._tasks.get(task_id)
        if not task or task["status"] != "pending":
            return False

        # Check dependencies
        for dep_id in task.get("blocked_by", []):
            dep = self._tasks.get(dep_id)
            if dep and dep["status"] != "completed":
                return False

        task["status"] = "in_progress"
        task["started_at"] = time.time()
        task["worker_id"] = worker_id
        return True

    async def wait_for_completion(
        self,
        execution_id: str,
        timeout: int | None = None,
    ) -> list[dict[str, Any]]:
        """Wait for all tasks in an execution to complete."""
        timeout = timeout or settings.task_timeout
        event = self._completion_events.get(execution_id)
        if not event:
            return []

        try:
            await asyncio.wait_for(event.wait(), timeout=timeout)
        except asyncio.TimeoutError:
            logger.warning(f"Execution {execution_id} timed out after {timeout}s")
            # Mark remaining pending tasks as timed out
            for task_id in self._executions.get(execution_id, []):
                task = self._tasks.get(task_id)
                if task and task["status"] in ("pending", "in_progress"):
                    task["status"] = "failed"
                    task["error"] = "Timed out"

        return [
            self._tasks[tid]
            for tid in self._executions.get(execution_id, [])
            if tid in self._tasks
        ]

    def _is_execution_complete(self, execution_id: str) -> bool:
        """Check if all tasks in an execution are in a terminal state."""
        task_ids = self._executions.get(execution_id, [])
        return all(
            self._tasks.get(tid, {}).get("status") in ("completed", "failed", "cancelled")
            for tid in task_ids
        )


_task_manager: TaskManager | None = None


def get_task_manager() -> TaskManager:
    global _task_manager
    if _task_manager is None:
        _task_manager = TaskManager()
    return _task_manager
