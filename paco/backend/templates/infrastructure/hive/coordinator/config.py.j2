"""
{{ infra.display_name or infra.name }} - Hive Coordinator Configuration
Generated by PACO Infrastructure Manager
"""

import os
from functools import lru_cache

from pydantic_settings import BaseSettings


class CoordinatorSettings(BaseSettings):
    anthropic_api_key: str = os.getenv("ANTHROPIC_API_KEY", "")
    database_url: str = os.getenv("DATABASE_URL", "postgresql+asyncpg://postgres:postgres@localhost:5432/{{ infra.db_name or infra.name }}")
    redis_url: str = os.getenv("REDIS_URL", "redis://localhost:6379")
    log_level: str = os.getenv("LOG_LEVEL", "INFO")

    host: str = "0.0.0.0"
    port: int = 8000

    coordinator_model: str = "{{ coordinator.coordinator_model }}"
    coordinator_temperature: float = {{ coordinator.coordinator_temperature }}

    max_concurrent_tasks: int = {{ coordinator.max_concurrent_tasks }}
    task_timeout: int = {{ coordinator.task_timeout }}
    max_retries: int = {{ coordinator.max_retries }}
    aggregation_strategy: str = "{{ coordinator.aggregation_strategy }}"
    plan_mode_enabled: bool = {{ coordinator.plan_mode_enabled }}

{% if coordinator.decomposition_prompt %}
    decomposition_prompt: str = """{{ coordinator.decomposition_prompt }}"""
{% else %}
    decomposition_prompt: str = ""
{% endif %}
{% if coordinator.aggregation_prompt %}
    aggregation_prompt: str = """{{ coordinator.aggregation_prompt }}"""
{% else %}
    aggregation_prompt: str = ""
{% endif %}

{% for agent in agents %}
    worker_{{ agent.category_code | lower }}_url: str = os.getenv("WORKER_{{ agent.category_code }}_URL", "http://localhost:{{ infra.port_range_start + loop.index }}")
{% endfor %}

    class Config:
        env_file = ".env"
        case_sensitive = False


@lru_cache()
def get_settings() -> CoordinatorSettings:
    return CoordinatorSettings()


def get_worker_registry() -> dict[str, dict[str, str]]:
    settings = get_settings()
    return {
{% for agent in agents %}
        "{{ agent.agent_id_slug }}": {
            "name": "{{ agent.display_name or agent.agent_id_slug }}",
            "category_code": "{{ agent.category_code }}",
            "url": settings.worker_{{ agent.category_code | lower }}_url,
            "description": "{{ agent.description or '' }}",
        },
{% endfor %}
    }
