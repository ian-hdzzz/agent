"""
{{ infra.display_name or infra.name }} - Task Decomposer
Generated by PACO Infrastructure Manager

Decomposes user requests into subtasks assigned to worker agents.
"""

import json
import logging
from typing import Any

import anthropic

from .config import get_settings

logger = logging.getLogger(__name__)

settings = get_settings()

AGENT_DESCRIPTIONS = """
Available agents:
{% for agent in agents %}
- slug: {{ agent.agent_id_slug }}
  name: {{ agent.display_name or agent.agent_id_slug }}
  category: {{ agent.category_code }}
  description: {{ agent.description or 'General agent' }}
  capabilities: {{ agent.task_types | join(', ') }}
{% endfor %}
"""

DEFAULT_DECOMPOSITION_PROMPT = """You are a task decomposition engine for a multi-agent system.

Given a user request and a list of available agents, decompose the request into subtasks
that can be executed by the agents. Each subtask should be assigned to the most appropriate agent.

{agent_descriptions}

Rules:
1. Each subtask must have: subject, description, assigned_agent_slug, priority (1-5, 1=highest), dependencies
2. Only assign subtasks to agents listed above (use their slug)
3. If tasks depend on each other, specify blocked_by with the subjects of prerequisite tasks
4. Tasks with no dependencies can run in parallel
5. Return a JSON array of task objects

Return ONLY valid JSON, no markdown or explanation.

Example format:
[
  {{
    "subject": "Look up account information",
    "description": "Find the user's account details",
    "assigned_agent_slug": "agent-slug",
    "priority": 1,
    "blocked_by": []
  }}
]"""


async def decompose_request(
    message: str,
    agent_descriptions: list[dict[str, str]],
    metadata: dict[str, Any] | None = None,
) -> list[dict[str, Any]]:
    """Decompose a user request into subtasks for worker agents."""
    client = anthropic.AsyncAnthropic(api_key=settings.anthropic_api_key)

    # Build agent info for the prompt
    agents_info = "\n".join(
        f"- {a['slug']}: {a['name']} - {a['description']}"
        for a in agent_descriptions
    )

    decomposition_prompt = settings.decomposition_prompt or DEFAULT_DECOMPOSITION_PROMPT
    system_prompt = decomposition_prompt.format(
        agent_descriptions=agents_info,
    )

    try:
        response = await client.messages.create(
            model=settings.coordinator_model,
            max_tokens=2048,
            temperature=settings.coordinator_temperature,
            system=system_prompt,
            messages=[
                {"role": "user", "content": message},
            ],
        )

        content = response.content[0].text.strip()

        # Parse JSON from response
        if content.startswith("```"):
            content = content.split("\n", 1)[1].rsplit("```", 1)[0].strip()

        tasks = json.loads(content)

        if not isinstance(tasks, list):
            logger.error("Decomposition did not return a list")
            return []

        # Validate each task
        valid_slugs = {a["slug"] for a in agent_descriptions}
        validated = []
        for task in tasks:
            if not isinstance(task, dict):
                continue
            if task.get("assigned_agent_slug") not in valid_slugs:
                logger.warning(f"Unknown agent slug: {task.get('assigned_agent_slug')}")
                continue
            validated.append({
                "subject": task.get("subject", "Untitled task"),
                "description": task.get("description", ""),
                "assigned_agent_slug": task["assigned_agent_slug"],
                "priority": task.get("priority", 3),
                "blocked_by": task.get("blocked_by", []),
            })

        return validated

    except json.JSONDecodeError as e:
        logger.error(f"Failed to parse decomposition response: {e}")
        return []
    except Exception as e:
        logger.error(f"Decomposition error: {e}")
        return []
