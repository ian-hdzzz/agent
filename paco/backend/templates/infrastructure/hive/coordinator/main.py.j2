@app.post("/process", response_model=ProcessResponse)
async def process_request(request: ProcessRequest):
    try:
        execution_id = str(uuid.uuid4())
        task_manager = get_task_manager()
        messenger = get_messenger()
        registry = get_worker_registry()

        # Step 1: Decompose request into subtasks
        agent_descriptions = [
            {"slug": slug, "name": info["name"], "description": info["description"]}
            for slug, info in registry.items()
        ]
        subtasks = await decompose_request(
            message=request.message,
            agent_descriptions=agent_descriptions,
            metadata=request.metadata,
        )

        if not subtasks:
            return ProcessResponse(
                response="I could not determine how to process this request.",
                execution_id=execution_id,
                tasks_created=0,
                tasks_completed=0,
                tasks_failed=0,
            )

        # Step 2: Create tasks from decomposition
        tasks = task_manager.create_tasks(execution_id, subtasks)
        logger.info(f"Execution {execution_id}: created {len(tasks)} tasks")

        # Step 3: Send tasks to workers
        for task in tasks:
            if not task.get("blocked_by"):
                agent_slug = task["assigned_agent_slug"]
                if agent_slug in registry:
                    worker_url = registry[agent_slug]["url"]
                    await messenger.send_task(
                        worker_url=worker_url,
                        task=task,
                        execution_id=execution_id,
                    )
                    task_manager.update_status(task["id"], "in_progress")

        # Step 4: Wait for results
        results = await task_manager.wait_for_completion(
            execution_id,
            timeout=settings.task_timeout,
        )

        # Step 5: Aggregate results
        completed = [r for r in results if r.get("status") == "completed"]
        failed = [r for r in results if r.get("status") == "failed"]

        final_response = await aggregate_results(
            results=completed,
            original_message=request.message,
            strategy=settings.aggregation_strategy,
        )

        return ProcessResponse(
            response=final_response,
            execution_id=execution_id,
            tasks_created=len(tasks),
            tasks_completed=len(completed),
            tasks_failed=len(failed),
        )

    except Exception as e:
        logger.error(f"Process error: {e}")
        raise HTTPException(status_code=500, detail=f"Coordinator error: {str(e)}")


@app.post("/tasks/{task_id}/complete")
async def task_complete(task_id: str, result: dict[str, Any]):
    """Called by workers to report task completion."""
    task_manager = get_task_manager()
    task_manager.complete_task(task_id, result)

    # Check if dependent tasks can now be unblocked
    messenger = get_messenger()
    registry = get_worker_registry()
    unblocked = task_manager.get_unblocked_tasks(task_id)
    for task in unblocked:
        agent_slug = task["assigned_agent_slug"]
        if agent_slug in registry:
            worker_url = registry[agent_slug]["url"]
            await messenger.send_task(
                worker_url=worker_url,
                task=task,
                execution_id=task.get("execution_id", ""),
            )
            task_manager.update_status(task["id"], "in_progress")

    return {"status": "ok"}


@app.post("/tasks/{task_id}/fail")
async def task_fail(task_id: str, error: dict[str, Any]):
    """Called by workers to report task failure."""
    task_manager = get_task_manager()
    task_manager.fail_task(task_id, error.get("message", "Unknown error"))
    return {"status": "ok"}


