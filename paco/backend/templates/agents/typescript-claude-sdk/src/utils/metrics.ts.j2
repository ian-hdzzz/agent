/**
 * {{ agent.display_name }} — Prometheus Metrics
 * Generated by PACO
 */

import { Registry, Counter, Histogram, Gauge, collectDefaultMetrics } from 'prom-client';
import { config } from '../config/index.js';

export const registry = new Registry();

if (config.metricsEnabled) {
  collectDefaultMetrics({ register: registry });
}

export const messagesTotal = new Counter({
  name: 'agent_messages_total',
  help: 'Total messages processed',
  labelNames: ['skill', 'status'],
  registers: [registry],
});

export const responseLatency = new Histogram({
  name: 'agent_response_latency_seconds',
  help: 'Response latency in seconds',
  labelNames: ['skill'],
  buckets: [0.1, 0.5, 1, 2, 5, 10, 30],
  registers: [registry],
});

export const toolCallsTotal = new Counter({
  name: 'agent_tool_calls_total',
  help: 'Total tool calls made',
  labelNames: ['tool', 'status'],
  registers: [registry],
});

export const classificationsTotal = new Counter({
  name: 'agent_classifications_total',
  help: 'Total message classifications',
  labelNames: ['skill', 'method'],
  registers: [registry],
});

export const activeConversations = new Gauge({
  name: 'agent_active_conversations',
  help: 'Number of active conversations',
  registers: [registry],
});

export const errorRate = new Gauge({
  name: 'agent_error_rate',
  help: 'Current error rate (0-1)',
  registers: [registry],
});
