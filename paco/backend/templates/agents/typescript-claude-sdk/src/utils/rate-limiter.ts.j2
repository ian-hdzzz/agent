/**
 * {{ agent.display_name }} — Rate Limiter
 * Generated by PACO — 3 limiters: conversation, API, budget
 */

import { config } from '../config/index.js';

interface RateBucket {
  count: number;
  resetAt: number;
}

class RateLimiter {
  private buckets = new Map<string, RateBucket>();
  private limit: number;
  private windowMs: number;

  constructor(limit: number, windowMs: number = 60_000) {
    this.limit = limit;
    this.windowMs = windowMs;
  }

  check(key: string): boolean {
    const now = Date.now();
    const bucket = this.buckets.get(key);

    if (!bucket || now > bucket.resetAt) {
      this.buckets.set(key, { count: 1, resetAt: now + this.windowMs });
      return true;
    }

    if (bucket.count >= this.limit) {
      return false;
    }

    bucket.count++;
    return true;
  }

  remaining(key: string): number {
    const now = Date.now();
    const bucket = this.buckets.get(key);
    if (!bucket || now > bucket.resetAt) return this.limit;
    return Math.max(0, this.limit - bucket.count);
  }
}

// Conversation limiter: max messages per conversation per minute
export const conversationLimiter = new RateLimiter(
  config.rateLimitConversation,
  60_000,
);

// API limiter: max total API calls per minute
export const apiLimiter = new RateLimiter(
  config.rateLimitApi,
  60_000,
);

// Budget limiter: max tool calls per conversation per hour
export const budgetLimiter = new RateLimiter(
  config.rateLimitBudget,
  3_600_000,
);
