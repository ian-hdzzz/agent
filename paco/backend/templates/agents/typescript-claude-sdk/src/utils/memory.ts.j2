/**
 * {{ agent.display_name }} — Conversation Memory
 * Generated by PACO — SQLite persistent store
 */

import Database from 'better-sqlite3';
import { config } from '../config/index.js';
import type { Message } from '../types.js';
import * as fs from 'fs';
import * as path from 'path';

// Ensure data directory exists
const dbDir = path.dirname(config.memoryDbPath);
if (!fs.existsSync(dbDir)) {
  fs.mkdirSync(dbDir, { recursive: true });
}

const db = new Database(config.memoryDbPath);

// Initialize schema
db.exec(`
  CREATE TABLE IF NOT EXISTS conversations (
    conversation_id TEXT NOT NULL,
    role TEXT NOT NULL,
    content TEXT NOT NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
  );
  CREATE INDEX IF NOT EXISTS idx_conv_id ON conversations(conversation_id);
  CREATE INDEX IF NOT EXISTS idx_conv_created ON conversations(created_at);
`);

// Prepared statements
const insertStmt = db.prepare(
  'INSERT INTO conversations (conversation_id, role, content) VALUES (?, ?, ?)'
);
const selectStmt = db.prepare(
  `SELECT role, content FROM conversations
   WHERE conversation_id = ?
   ORDER BY created_at DESC
   LIMIT ?`
);
const cleanupStmt = db.prepare(
  `DELETE FROM conversations WHERE created_at < datetime('now', '-' || ? || ' days')`
);

/**
 * Save a message to conversation memory.
 */
export function saveMessage(conversationId: string, role: string, content: string): void {
  insertStmt.run(conversationId, role, content);
}

/**
 * Get recent messages for a conversation.
 */
export function getMessages(conversationId: string, limit?: number): Message[] {
  const rows = selectStmt.all(conversationId, limit || config.memoryMaxMessages) as Array<{ role: string; content: string }>;
  return rows.reverse().map(row => ({
    role: row.role as 'user' | 'assistant',
    content: row.content,
  }));
}

/**
 * Clean up old messages beyond retention period.
 */
export function cleanup(): void {
  cleanupStmt.run(config.memoryRetentionDays);
}

// Run cleanup on startup and periodically
cleanup();
setInterval(cleanup, 24 * 60 * 60 * 1000); // Daily
