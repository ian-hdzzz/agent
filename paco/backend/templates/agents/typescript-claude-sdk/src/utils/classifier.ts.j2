/**
 * {{ agent.display_name }} — Message Classifier
 * Generated by PACO — LLM + keyword fallback
 */

import Anthropic from '@anthropic-ai/sdk';
import { config } from '../config/index.js';
import { SKILL_REGISTRY, buildClassificationContext } from '../skills/index.js';
import type { ClassificationResult } from '../types.js';

const anthropic = new Anthropic({ apiKey: config.anthropicApiKey });

/**
 * Classify a user message into a skill and optional subcategory.
 * Uses LLM classification with keyword fallback.
 */
export async function classifyMessage(
  message: string,
  conversationHistory: string[] = [],
): Promise<ClassificationResult> {
  // Try keyword classification first (fast path)
  const keywordResult = classifyByKeywords(message);
  if (keywordResult && keywordResult.confidence >= 0.8) {
    return keywordResult;
  }

  // LLM classification
  try {
    const llmResult = await classifyByLLM(message, conversationHistory);
    if (llmResult) {
      return llmResult;
    }
  } catch (err) {
    console.error('[Classifier] LLM classification failed, using keyword fallback:', err);
  }

  // Return keyword result if available, otherwise default
  if (keywordResult) {
    return keywordResult;
  }

  // Default to first skill
  const firstSkill = Object.keys(SKILL_REGISTRY)[0];
  return {
    skillCode: firstSkill || 'general',
    confidence: 0.1,
    method: 'keyword',
  };
}

function classifyByKeywords(message: string): ClassificationResult | null {
  const lower = message.toLowerCase();
  let bestMatch: ClassificationResult | null = null;
  let bestScore = 0;

  for (const [code, skill] of Object.entries(SKILL_REGISTRY)) {
    let score = 0;
    for (const keyword of skill.keywords) {
      if (lower.includes(keyword.toLowerCase())) {
        score++;
      }
    }

    if (score > bestScore) {
      bestScore = score;
      // Also try to match subcategory
      let subcategoryCode: string | undefined;
      for (const sub of skill.subcategories) {
        const subName = sub.name.toLowerCase();
        if (lower.includes(subName)) {
          subcategoryCode = sub.code;
          break;
        }
      }

      bestMatch = {
        skillCode: code,
        subcategoryCode,
        confidence: Math.min(score * 0.3, 0.9),
        method: 'keyword',
      };
    }
  }

  return bestMatch;
}

async function classifyByLLM(
  message: string,
  conversationHistory: string[],
): Promise<ClassificationResult | null> {
  const context = buildClassificationContext();
  const historyText = conversationHistory.length > 0
    ? `\nHistorial reciente:\n${conversationHistory.slice(-3).join('\n')}`
    : '';

  const response = await anthropic.messages.create({
    model: config.classifierModel,
    max_tokens: 100,
    temperature: config.classifierTemperature,
    messages: [{
      role: 'user',
      content: `Clasifica este mensaje del usuario en una de las siguientes categorías.

Categorías disponibles:
${context}

Mensaje: "${message}"${historyText}

Responde SOLO con JSON: {"skill": "codigo", "subcategory": "codigo_sub", "confidence": 0.0-1.0}`,
    }],
  });

  const text = response.content[0]?.type === 'text' ? response.content[0].text : '';
  try {
    const parsed = JSON.parse(text.trim());
    if (parsed.skill && SKILL_REGISTRY[parsed.skill]) {
      return {
        skillCode: parsed.skill,
        subcategoryCode: parsed.subcategory,
        confidence: parsed.confidence || 0.7,
        method: 'llm',
      };
    }
  } catch {
    // Parse failed, return null to trigger fallback
  }

  return null;
}
