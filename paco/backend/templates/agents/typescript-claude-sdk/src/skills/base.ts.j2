import { readFileSync } from 'fs';
import { join, dirname } from 'path';
import { fileURLToPath } from 'url';
import type { SkillDefinition, Subcategory } from '../types.js';

{% if conversation_rules %}
/**
 * Global conversation rules applied to ALL skills.
 */
export const CONVERSATION_RULES = `
{{ conversation_rules }}
`;
{% else %}
export const CONVERSATION_RULES = '';
{% endif %}

/**
 * Build the full system prompt for a skill, including global rules.
 */
export function buildSystemPrompt(skill: SkillDefinition): string {
  let prompt = skill.systemPrompt;
  if (CONVERSATION_RULES) {
    prompt = CONVERSATION_RULES + '\n\n' + prompt;
  }
  return prompt;
}

/**
 * Load a bundled resource file for a skill.
 * Resource files are stored alongside the skill code in src/skills/{code}/.
 */
export function loadSkillResource(skillCode: string, resourcePath: string): string {
  const __dirname = dirname(fileURLToPath(import.meta.url));
  const skillDir = join(__dirname, skillCode);
  return readFileSync(join(skillDir, resourcePath), 'utf-8');
}
