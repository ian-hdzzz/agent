/**
 * {{ agent.display_name }} — Skill Registry
 * Generated by PACO
 */

import type { SkillDefinition } from '../types.js';
{% for skill in skills %}
import { {{ skill.code }}Skill } from './{{ skill.code }}.js';
{% endfor %}

export const SKILL_REGISTRY: Record<string, SkillDefinition> = {
{% for skill in skills %}
  '{{ skill.code }}': {{ skill.code }}Skill,
{% endfor %}
};

/**
 * Get all skill codes.
 */
export function getSkillCodes(): string[] {
  return Object.keys(SKILL_REGISTRY);
}

/**
 * Get skill by code, or undefined.
 */
export function getSkill(code: string): SkillDefinition | undefined {
  return SKILL_REGISTRY[code];
}

/**
 * Build a classification prompt listing all available skills.
 * Uses Level 1 data only (description) for progressive disclosure.
 */
export function buildClassificationContext(): string {
  const lines: string[] = [];
  for (const [code, skill] of Object.entries(SKILL_REGISTRY)) {
    lines.push(`- ${code} (${skill.name}): ${skill.description}`);
  }
  return lines.join('\n');
}
