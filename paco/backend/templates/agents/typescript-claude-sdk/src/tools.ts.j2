import { config } from './config/index.js';
import { toolCache } from './utils/cache.js';
import { toolCallsTotal } from './utils/metrics.js';
import type { ToolResult } from './types.js';

/**
 * Tool definitions for the Anthropic SDK.
 */
export const TOOL_DEFINITIONS: Array<{
  name: string;
  description: string;
  input_schema: Record<string, unknown>;
}> = [
{% for tool in tools %}
  {
    name: '{{ tool.name }}',
    description: `{{ tool.description | replace('`', '\\`') }}`,
    input_schema: {{ tool.input_schema | tojson }},
  },
{% endfor %}
];

/**
 * Get tool definitions filtered by skill requirements.
 */
export function getToolsForSkill(toolNames: string[]): typeof TOOL_DEFINITIONS {
  if (toolNames.length === 0) return TOOL_DEFINITIONS;
  return TOOL_DEFINITIONS.filter(t => toolNames.includes(t.name));
}

/**
 * Execute a tool by name with given input.
 */
export async function executeTool(
  toolName: string,
  input: Record<string, unknown>,
): Promise<ToolResult> {
  const startTime = Date.now();

  try {
    // Check cache for read-only tools
    const cacheKey = `${toolName}:${JSON.stringify(input)}`;
    const cached = toolCache.get(cacheKey);
    if (cached) {
      toolCallsTotal.inc({ tool: toolName, status: 'cache_hit' });
      return cached as ToolResult;
    }

    let result: ToolResult;

    switch (toolName) {
{% for tool in tools %}
      case '{{ tool.name }}':
{% if tool.mcp_server_url %}
        result = await callMcpTool('{{ tool.mcp_server_name }}', '{{ tool.name }}', input);
{% else %}
        result = { success: false, error: 'Tool {{ tool.name }} has no MCP server configured' };
{% endif %}
        break;
{% endfor %}
      default:
        result = { success: false, error: `Unknown tool: ${toolName}` };
    }

    // Cache successful results
    if (result.success) {
      toolCache.set(cacheKey, result);
    }

    const latency = Date.now() - startTime;
    toolCallsTotal.inc({ tool: toolName, status: result.success ? 'success' : 'error' });
    console.log(`[Tool] ${toolName} completed in ${latency}ms (success: ${result.success})`);

    return result;
  } catch (error) {
    toolCallsTotal.inc({ tool: toolName, status: 'error' });
    const errMsg = error instanceof Error ? error.message : String(error);
    console.error(`[Tool] ${toolName} failed:`, errMsg);
    return { success: false, error: errMsg };
  }
}

/**
 * Call a tool via its MCP server's HTTP endpoint.
 */
async function callMcpTool(
  serverName: string,
  toolName: string,
  input: Record<string, unknown>,
): Promise<ToolResult> {
  const serverUrls: Record<string, string> = {
{% for name, server in mcp_servers.items() %}
    '{{ name }}': config.mcpServer_{{ name | replace('-', '_') }},
{% endfor %}
  };

  const baseUrl = serverUrls[serverName];
  if (!baseUrl) {
    return { success: false, error: `MCP server '${serverName}' not configured` };
  }

  const response = await fetch(`${baseUrl}/tools/call`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name: toolName, arguments: input }),
    signal: AbortSignal.timeout(30_000),
  });

  if (!response.ok) {
    const text = await response.text();
    return { success: false, error: `MCP call failed (${response.status}): ${text}` };
  }

  const data = await response.json() as { content?: Array<{ text?: string }> };
  const content = data.content?.[0]?.text;

  try {
    return { success: true, data: content ? JSON.parse(content) : data };
  } catch {
    return { success: true, data: content || data };
  }
}
