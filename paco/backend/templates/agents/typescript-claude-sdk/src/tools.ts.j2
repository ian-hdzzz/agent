/**
 * {{ agent.display_name }} — Tool Definitions & MCP HTTP Calls
 * Generated by PACO — Supports dynamic tool loading via ConfigManager
 */

import { config } from './config/index.js';
import { configManager } from './config/config-manager.js';
import { toolCache } from './utils/cache.js';
import { toolCallsTotal } from './utils/metrics.js';
import type { ToolResult } from './types.js';

type ToolDef = {
  name: string;
  description: string;
  input_schema: Record<string, unknown>;
};

/**
 * Baked-in tool definitions (fallback if ConfigManager has no dynamic tools).
 */
const BAKED_TOOL_DEFINITIONS: ToolDef[] = [
{% for tool in tools %}
  {
    name: '{{ tool.name }}',
    description: `{{ tool.description | replace('`', '\\`') }}`,
    input_schema: {{ tool.input_schema | tojson }},
  },
{% endfor %}
];

/**
 * Baked-in tool → MCP server mapping.
 */
const BAKED_TOOL_SERVERS: Record<string, string> = {
{% for tool in tools %}
{% if tool.mcp_server_name %}
  '{{ tool.name }}': '{{ tool.mcp_server_name }}',
{% endif %}
{% endfor %}
};

/**
 * Get current tool definitions — dynamic from ConfigManager if available,
 * otherwise baked-in defaults.
 */
export function getToolDefinitions(): ToolDef[] {
  const dynamicTools = configManager.getConfig().tools;
  if (dynamicTools.length > 0) {
    return dynamicTools.map(t => ({
      name: t.name,
      description: t.description,
      input_schema: t.input_schema,
    }));
  }
  return BAKED_TOOL_DEFINITIONS;
}

/**
 * For backward compatibility — re-export as TOOL_DEFINITIONS.
 */
export const TOOL_DEFINITIONS = BAKED_TOOL_DEFINITIONS;

/**
 * Get tool definitions filtered by skill requirements.
 */
export function getToolsForSkill(
  toolNames: string[],
  toolDefs?: ToolDef[],
): ToolDef[] {
  const defs = toolDefs || getToolDefinitions();
  if (toolNames.length === 0) return defs;
  return defs.filter(t => toolNames.includes(t.name));
}

/**
 * Resolve which MCP server a tool belongs to.
 * Checks dynamic config first, falls back to baked-in mapping.
 */
function resolveToolServer(toolName: string): string | null {
  // Check dynamic config
  const dynamicTools = configManager.getConfig().tools;
  const dynamicTool = dynamicTools.find(t => t.name === toolName);
  if (dynamicTool?.mcp_server_name) {
    return dynamicTool.mcp_server_name;
  }
  // Fallback to baked-in
  return BAKED_TOOL_SERVERS[toolName] || null;
}

/**
 * Execute a tool by name with given input.
 */
export async function executeTool(
  toolName: string,
  input: Record<string, unknown>,
): Promise<ToolResult> {
  const startTime = Date.now();

  try {
    // Check cache for read-only tools
    const cacheKey = `${toolName}:${JSON.stringify(input)}`;
    const cached = toolCache.get(cacheKey);
    if (cached) {
      toolCallsTotal.inc({ tool: toolName, status: 'cache_hit' });
      return cached as ToolResult;
    }

    let result: ToolResult;

    const serverName = resolveToolServer(toolName);
    if (serverName) {
      result = await callMcpTool(serverName, toolName, input);
    } else {
      result = { success: false, error: `Unknown tool or no MCP server: ${toolName}` };
    }

    // Cache successful results
    if (result.success) {
      toolCache.set(cacheKey, result);
    }

    const latency = Date.now() - startTime;
    toolCallsTotal.inc({ tool: toolName, status: result.success ? 'success' : 'error' });
    console.log(`[Tool] ${toolName} completed in ${latency}ms (success: ${result.success})`);

    return result;
  } catch (error) {
    toolCallsTotal.inc({ tool: toolName, status: 'error' });
    const errMsg = error instanceof Error ? error.message : String(error);
    console.error(`[Tool] ${toolName} failed:`, errMsg);
    return { success: false, error: errMsg };
  }
}

/**
 * Resolve MCP server URL — checks dynamic config first, then static config.
 */
function resolveMcpServerUrl(serverName: string): string | null {
  // Check dynamic config from ConfigManager
  const dynamicServers = configManager.getConfig().mcpServers;
  if (dynamicServers[serverName]?.url) {
    return dynamicServers[serverName].url;
  }

  // Fallback to baked-in static config
  const staticUrls: Record<string, string> = {
{% for name, server in mcp_servers.items() %}
    '{{ name }}': config.mcpServer_{{ name | replace('-', '_') }},
{% endfor %}
  };

  return staticUrls[serverName] || null;
}

/**
 * Call a tool via its MCP server's HTTP endpoint.
 */
async function callMcpTool(
  serverName: string,
  toolName: string,
  input: Record<string, unknown>,
): Promise<ToolResult> {
  const baseUrl = resolveMcpServerUrl(serverName);
  if (!baseUrl) {
    return { success: false, error: `MCP server '${serverName}' not configured` };
  }

  const response = await fetch(`${baseUrl}/tools/call`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name: toolName, arguments: input }),
    signal: AbortSignal.timeout(30_000),
  });

  if (!response.ok) {
    const text = await response.text();
    return { success: false, error: `MCP call failed (${response.status}): ${text}` };
  }

  const data = await response.json() as { content?: Array<{ text?: string }> };
  const content = data.content?.[0]?.text;

  try {
    return { success: true, data: content ? JSON.parse(content) : data };
  } catch {
    return { success: true, data: content || data };
  }
}
