/**
 * {{ agent.display_name }} — Agent Core
 * Generated by PACO — Workflow: classify -> skill -> tools -> response
 */

import Anthropic from '@anthropic-ai/sdk';
import { config } from './config/index.js';
import { SKILL_REGISTRY, getSkill } from './skills/index.js';
import { buildSystemPrompt } from './skills/base.js';
import { getToolsForSkill, executeTool, TOOL_DEFINITIONS } from './tools.js';
import { classifyMessage } from './utils/classifier.js';
import { saveMessage, getMessages } from './utils/memory.js';
import { conversationLimiter, budgetLimiter } from './utils/rate-limiter.js';
import { messagesTotal, responseLatency, classificationsTotal } from './utils/metrics.js';
import { RESPONSE_TEMPLATES } from './config/response-templates.js';
import type { ChatRequest, ChatResponse, Message } from './types.js';

const anthropic = new Anthropic({ apiKey: config.anthropicApiKey });

/**
 * Process a chat message through the full agent pipeline:
 * 1. Rate limit check
 * 2. Load conversation history from memory
 * 3. Classify message into a skill
 * 4. Build system prompt for that skill
 * 5. Call Claude with skill-specific tools
 * 6. Handle tool calls in a loop
 * 7. Save to memory and return response
 */
export async function processMessage(request: ChatRequest): Promise<ChatResponse> {
  const { message, conversationId, contactId } = request;
  const startTime = Date.now();
  let skillUsed: string | undefined;
  const toolsUsed: string[] = [];

  try {
    // 1. Rate limit
    if (!conversationLimiter.check(conversationId)) {
      messagesTotal.inc({ skill: 'rate_limited', status: 'rejected' });
      return {
        response: RESPONSE_TEMPLATES.RATE_LIMITED,
        conversationId,
      };
    }

    // 2. Load history
    const history = getMessages(conversationId);
    const historyMessages = history.map(m => ({
      role: m.role as 'user' | 'assistant',
      content: m.content,
    }));

    // 3. Classify
    const classification = await classifyMessage(
      message,
      history.filter(m => m.role === 'user').map(m => m.content),
    );
    skillUsed = classification.skillCode;
    classificationsTotal.inc({ skill: skillUsed, method: classification.method });

    // 4. Get skill and build prompt
    const skill = getSkill(skillUsed);
    if (!skill) {
      console.error(`[Agent] Skill '${skillUsed}' not found in registry`);
      return {
        response: RESPONSE_TEMPLATES.ERROR,
        conversationId,
      };
    }

    const systemPrompt = buildSystemPrompt(skill);
    const skillTools = getToolsForSkill(skill.tools);

    // 5. Build messages array
    const messages: Array<{ role: 'user' | 'assistant'; content: string | Array<Record<string, unknown>> }> = [
      ...historyMessages,
      { role: 'user', content: message },
    ];

    // 6. Claude conversation loop with tool use
    let response = await anthropic.messages.create({
      model: config.model,
      max_tokens: config.maxTokens,
      system: systemPrompt,
      messages,
      tools: skillTools.length > 0 ? skillTools as Anthropic.Tool[] : undefined,
    });

    // Handle tool use in a loop (max 10 iterations)
    let iterations = 0;
    while (response.stop_reason === 'tool_use' && iterations < 10) {
      iterations++;

      // Check budget limiter
      if (!budgetLimiter.check(conversationId)) {
        break;
      }

      const toolUseBlocks = response.content.filter(
        (b): b is Anthropic.ToolUseBlock => b.type === 'tool_use'
      );

      const toolResults: Array<{
        type: 'tool_result';
        tool_use_id: string;
        content: string;
      }> = [];

      for (const toolUse of toolUseBlocks) {
        const result = await executeTool(
          toolUse.name,
          toolUse.input as Record<string, unknown>,
        );
        toolsUsed.push(toolUse.name);
        toolResults.push({
          type: 'tool_result',
          tool_use_id: toolUse.id,
          content: JSON.stringify(result.data || result.error),
        });
      }

      // Continue the conversation with tool results
      messages.push({ role: 'assistant', content: response.content as unknown as Array<Record<string, unknown>> });
      messages.push({ role: 'user', content: toolResults as unknown as Array<Record<string, unknown>> });

      response = await anthropic.messages.create({
        model: config.model,
        max_tokens: config.maxTokens,
        system: systemPrompt,
        messages,
        tools: skillTools.length > 0 ? skillTools as Anthropic.Tool[] : undefined,
      });
    }

    // 7. Extract text response
    const textBlocks = response.content.filter(
      (b): b is Anthropic.TextBlock => b.type === 'text'
    );
    const responseText = textBlocks.map(b => b.text).join('\n') || RESPONSE_TEMPLATES.ERROR;

    // Save to memory
    saveMessage(conversationId, 'user', message);
    saveMessage(conversationId, 'assistant', responseText);

    const latency = (Date.now() - startTime) / 1000;
    messagesTotal.inc({ skill: skillUsed, status: 'success' });
    responseLatency.observe({ skill: skillUsed }, latency);

    return {
      response: responseText,
      conversationId,
      skillUsed,
      toolsUsed: toolsUsed.length > 0 ? toolsUsed : undefined,
    };
  } catch (error) {
    const errMsg = error instanceof Error ? error.message : String(error);
    console.error('[Agent] Error processing message:', errMsg);
    messagesTotal.inc({ skill: skillUsed || 'unknown', status: 'error' });

    return {
      response: RESPONSE_TEMPLATES.ERROR,
      conversationId,
    };
  }
}
