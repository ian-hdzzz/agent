/**
 * {{ agent.display_name }} — Dynamic Config Manager
 * Generated by PACO — Fetches live config from PACO API at runtime
 */

interface McpServerConfig {
  name: string;
  url: string;
  transport: string;
  auth_config?: Record<string, unknown>;
}

interface ToolConfig {
  name: string;
  description: string;
  input_schema: Record<string, unknown>;
  mcp_server_name: string | null;
  mcp_server_url: string | null;
}

interface SkillConfig {
  code: string;
  name: string;
  description: string;
  allowed_tools: string[];
  is_enabled: boolean;
}

export interface DynamicConfig {
  model: string;
  systemPrompt: string;
  maxBudgetUsd: number | null;
  mcpServers: Record<string, McpServerConfig>;
  tools: ToolConfig[];
  skills: SkillConfig[];
  version: number;
}

// Baked-in defaults from generation time (fallback if PACO API is unreachable)
const BAKED_DEFAULTS: DynamicConfig = {
  model: '{{ agent.model if agent.model is defined else "claude-sonnet-4-5-20250929" }}',
  systemPrompt: `{{ agent.system_prompt | default("", true) | replace('`', '\\`') | replace('\\', '\\\\') }}`,
  maxBudgetUsd: {{ agent.max_budget_usd if agent.max_budget_usd is defined and agent.max_budget_usd else 'null' }},
  mcpServers: {
{% for name, server in mcp_servers.items() %}
    '{{ name }}': {
      name: '{{ name }}',
      url: '{{ server.url or "" }}',
      transport: '{{ server.transport or "http" }}',
    },
{% endfor %}
  },
  tools: [
{% for tool in tools %}
    {
      name: '{{ tool.name }}',
      description: `{{ tool.description | replace('`', '\\`') }}`,
      input_schema: {{ tool.input_schema | tojson }},
      mcp_server_name: {{ ("'" + tool.mcp_server_name + "'") if tool.mcp_server_name else 'null' }},
      mcp_server_url: {{ ("'" + tool.mcp_server_url + "'") if tool.mcp_server_url else 'null' }},
    },
{% endfor %}
  ],
  skills: [
{% for skill in skills %}
    {
      code: '{{ skill.code }}',
      name: '{{ skill.name }}',
      description: `{{ skill.description | replace('`', '\\`') }}`,
      allowed_tools: {{ skill.allowed_tools | tojson }},
      is_enabled: true,
    },
{% endfor %}
  ],
  version: 0,
};

class ConfigManager {
  private config: DynamicConfig;
  private pacoApiUrl: string | null;
  private agentId: string | null;
  private configVersion: number = 0;
  private lastFetchAt: number = 0;

  constructor() {
    this.config = { ...BAKED_DEFAULTS };
    this.pacoApiUrl = process.env.PACO_API_URL || null;
    this.agentId = process.env.PACO_AGENT_ID || null;
  }

  /**
   * Fetch live config from PACO API and update cache.
   * Returns true if config was updated, false if using baked defaults.
   */
  async reload(): Promise<boolean> {
    if (!this.pacoApiUrl || !this.agentId) {
      console.log('[ConfigManager] No PACO_API_URL or PACO_AGENT_ID set, using baked defaults');
      return false;
    }

    try {
      const url = `${this.pacoApiUrl}/api/agents/${this.agentId}`;
      const response = await fetch(url, {
        headers: { 'Content-Type': 'application/json' },
        signal: AbortSignal.timeout(10_000),
      });

      if (!response.ok) {
        console.error(`[ConfigManager] PACO API returned ${response.status}`);
        return false;
      }

      const data = await response.json() as Record<string, any>;
      this.applyApiResponse(data);
      this.configVersion++;
      this.lastFetchAt = Date.now();
      console.log(`[ConfigManager] Config reloaded (version ${this.configVersion})`);
      return true;
    } catch (error) {
      const errMsg = error instanceof Error ? error.message : String(error);
      console.error(`[ConfigManager] Failed to fetch config: ${errMsg}`);
      return false;
    }
  }

  private applyApiResponse(data: Record<string, any>): void {
    // Model and prompt
    if (data.model) {
      this.config.model = data.model;
    }
    if (data.system_prompt !== undefined) {
      this.config.systemPrompt = data.system_prompt || '';
    }
    if (data.max_budget_usd !== undefined) {
      this.config.maxBudgetUsd = data.max_budget_usd;
    }

    // MCP Servers from agent detail response
    if (data.mcp_servers && Array.isArray(data.mcp_servers)) {
      const servers: Record<string, McpServerConfig> = {};
      for (const srv of data.mcp_servers) {
        servers[srv.name] = {
          name: srv.name,
          url: srv.url || '',
          transport: srv.transport || 'http',
          auth_config: srv.auth_config,
        };
      }
      this.config.mcpServers = servers;
    }

    // Tools from agent detail response
    if (data.tools && Array.isArray(data.tools)) {
      this.config.tools = data.tools.map((t: any) => ({
        name: t.name,
        description: t.description || '',
        input_schema: t.input_schema || {},
        mcp_server_name: t.mcp_server_name || null,
        mcp_server_url: t.mcp_server_url || null,
      }));
    }

    // Skills from agent detail response
    if (data.skills && Array.isArray(data.skills)) {
      this.config.skills = data.skills.map((s: any) => ({
        code: s.skill_code || s.code,
        name: s.skill_name || s.name,
        description: s.description || '',
        allowed_tools: s.allowed_tools || [],
        is_enabled: s.is_enabled !== false,
      }));
    }
  }

  getConfig(): DynamicConfig {
    return this.config;
  }

  getVersion(): number {
    return this.configVersion;
  }

  getLastFetchAt(): number {
    return this.lastFetchAt;
  }

  isConnectedToPaco(): boolean {
    return !!(this.pacoApiUrl && this.agentId);
  }
}

export const configManager = new ConfigManager();
