/**
 * {{ agent.display_name }} — Configuration
 * Generated by PACO
 */

export const config = {
  // Agent
  agentName: '{{ agent.name }}',
  displayName: '{{ agent.display_name }}',
  port: parseInt(process.env.PORT || '{{ agent.port }}'),

  // Anthropic
  anthropicApiKey: process.env.ANTHROPIC_API_KEY || '',
  model: process.env.MODEL || 'claude-sonnet-4-5-20250929',
  maxTokens: parseInt(process.env.MAX_TOKENS || '4096'),

  // PACO Integration
  pacoApiUrl: process.env.PACO_API_URL || '',
  pacoAgentId: process.env.PACO_AGENT_ID || '',

  // Classifier
  classifierModel: '{{ classifier.get("model", "claude-sonnet-4-5-20250929") }}',
  classifierTemperature: {{ classifier.get("temperature", 0.1) }},
  classifierFallback: '{{ classifier.get("fallback", "keywords") }}',

  // Memory
  memoryType: '{{ memory.get("type", "sqlite") }}',
  memoryRetentionDays: {{ memory.get("retention_days", 30) }},
  memoryMaxMessages: {{ memory.get("max_messages", 20) }},
  memoryDbPath: process.env.MEMORY_DB_PATH || './data/memory.db',

  // Cache
  cacheTtlSeconds: {{ cache.get("ttl_seconds", 300) }},
  cacheCleanupInterval: {{ cache.get("cleanup_interval", 60) }},

  // Rate Limits
  rateLimitConversation: {{ rate_limits.get("conversation", 20) }},
  rateLimitApi: {{ rate_limits.get("api", 100) }},
  rateLimitBudget: {{ rate_limits.get("budget", 50) }},

  // Metrics
  metricsEnabled: {{ 'true' if metrics.get("prometheus", True) else 'false' }},
  healthErrorThreshold: {{ metrics.get("health_error_threshold", 0.1) }},

  // MCP Servers (baked defaults — overridden at runtime by ConfigManager)
{% for name, server in mcp_servers.items() %}
  mcpServer_{{ name | replace('-', '_') }}: process.env.MCP_{{ name | upper | replace('-', '_') }}_URL || '{{ server.url or "" }}',
{% endfor %}

  // Webhooks
{% if webhooks.get("chatwoot") %}
  chatwootUrl: process.env.CHATWOOT_URL || '{{ webhooks.chatwoot.get("url", "") }}',
  chatwootToken: process.env.CHATWOOT_TOKEN || '',
{% endif %}

  // Security
  confidentialityLevel: '{{ agent.confidentiality_level }}',
};
