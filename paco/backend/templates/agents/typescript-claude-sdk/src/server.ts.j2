/**
 * {{ agent.display_name }} — Express Server
 * Generated by PACO — /health, /metrics, /api/chat, /chatwoot
 */

import express from 'express';
import { config } from './config/index.js';
import { processMessage } from './agent.js';
import { registry, messagesTotal, errorRate } from './utils/metrics.js';
import type { ChatRequest{% if webhooks.get("chatwoot") %}, ChatwootWebhookPayload{% endif %} } from './types.js';

const app = express();
app.use(express.json());

// =============================================================================
// Health Check
// =============================================================================

app.get('/health', async (_req, res) => {
  try {
    const metrics = await registry.getMetricsAsJSON();
    const errorMetric = metrics.find(m => m.name === 'agent_error_rate');
    const currentErrorRate = errorMetric ? Number((errorMetric as { values?: Array<{ value: number }> }).values?.[0]?.value || 0) : 0;

    res.json({
      status: currentErrorRate > config.healthErrorThreshold ? 'degraded' : 'healthy',
      agent: config.agentName,
      version: '{{ agent.version }}',
      uptime: process.uptime(),
      errorRate: currentErrorRate,
    });
  } catch {
    res.json({
      status: 'healthy',
      agent: config.agentName,
      version: '{{ agent.version }}',
      uptime: process.uptime(),
    });
  }
});

// =============================================================================
// Prometheus Metrics
// =============================================================================

{% if metrics.get("prometheus", True) %}
app.get('/metrics', async (_req, res) => {
  try {
    res.set('Content-Type', registry.contentType);
    res.end(await registry.metrics());
  } catch (err) {
    res.status(500).end(String(err));
  }
});
{% endif %}

// =============================================================================
// Chat API
// =============================================================================

app.post('/api/chat', async (req, res) => {
  try {
    const { message, conversationId, contactId, metadata } = req.body as ChatRequest & { metadata?: Record<string, unknown> };

    if (!message || !conversationId) {
      res.status(400).json({ error: 'message and conversationId are required' });
      return;
    }

    const result = await processMessage({
      message,
      conversationId,
      contactId,
      metadata,
    });

    res.json(result);
  } catch (error) {
    const errMsg = error instanceof Error ? error.message : String(error);
    console.error('[Server] Chat error:', errMsg);
    res.status(500).json({ error: 'Internal server error' });
  }
});

{% if webhooks.get("chatwoot") %}
// =============================================================================
// Chatwoot Webhook
// =============================================================================

app.post('/chatwoot', async (req, res) => {
  try {
    const payload = req.body as ChatwootWebhookPayload;

    // Only process incoming messages
    if (payload.message_type !== 'incoming' && payload.event !== 'message_created') {
      res.json({ status: 'ignored' });
      return;
    }

    // Ignore messages from the bot itself
    if (payload.sender?.type === 'agent') {
      res.json({ status: 'ignored' });
      return;
    }

    const message = payload.content;
    const conversationId = String(payload.conversation?.id || payload.id);
    const contactId = payload.conversation?.contact_id
      ? String(payload.conversation.contact_id)
      : undefined;

    if (!message) {
      res.json({ status: 'no_content' });
      return;
    }

    // Process through agent
    const result = await processMessage({
      message,
      conversationId,
      contactId,
    });

    // Send response back to Chatwoot
    if (config.chatwootUrl && config.chatwootToken) {
      await fetch(
        `${config.chatwootUrl}/api/v1/accounts/1/conversations/${conversationId}/messages`,
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'api_access_token': config.chatwootToken,
          },
          body: JSON.stringify({
            content: result.response,
            message_type: 'outgoing',
            content_type: 'text',
          }),
        },
      );
    }

    res.json({ status: 'ok', skillUsed: result.skillUsed });
  } catch (error) {
    const errMsg = error instanceof Error ? error.message : String(error);
    console.error('[Chatwoot] Webhook error:', errMsg);
    res.status(500).json({ error: 'Webhook processing failed' });
  }
});
{% endif %}

// =============================================================================
// Start Server
// =============================================================================

app.listen(config.port, () => {
  console.log(`{{ agent.display_name }} running on port ${config.port}`);
  console.log(`  Health: http://localhost:${config.port}/health`);
{% if metrics.get("prometheus", True) %}
  console.log(`  Metrics: http://localhost:${config.port}/metrics`);
{% endif %}
  console.log(`  Chat: http://localhost:${config.port}/api/chat`);
{% if webhooks.get("chatwoot") %}
  console.log(`  Chatwoot: http://localhost:${config.port}/chatwoot`);
{% endif %}
});
