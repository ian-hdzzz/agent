"""
{{ agent.display_name }} — Message Classifier
Generated by PACO — Keyword + LLM classification
"""

import json
import logging
from dataclasses import dataclass
from typing import Optional

import anthropic

from config import settings
from skills import SKILL_REGISTRY

logger = logging.getLogger(__name__)


@dataclass
class ClassificationResult:
    skill_code: str
    subcategory_code: Optional[str] = None
    confidence: float = 0.0
    method: str = "keyword"


def classify_by_keywords(message: str) -> Optional[ClassificationResult]:
    """Fast keyword-based classification."""
    lower = message.lower()
    best_match = None
    best_score = 0

    for code, skill in SKILL_REGISTRY.items():
        score = sum(1 for kw in skill.keywords if kw.lower() in lower)
        if score > best_score:
            best_score = score
            sub_code = None
            for sub in skill.subcategories:
                if sub.name.lower() in lower:
                    sub_code = sub.code
                    break
            best_match = ClassificationResult(
                skill_code=code,
                subcategory_code=sub_code,
                confidence=min(score * 0.3, 0.9),
                method="keyword",
            )

    return best_match


def classify_by_llm(message: str, history: list[str] | None = None) -> Optional[ClassificationResult]:
    """LLM-based classification."""
    client = anthropic.Anthropic(api_key=settings.anthropic_api_key)

    categories = "\n".join(
        f"- {code} ({skill.name}): {', '.join(s.code for s in skill.subcategories)}"
        for code, skill in SKILL_REGISTRY.items()
    )

    history_text = ""
    if history:
        history_text = f"\nHistorial reciente:\n" + "\n".join(history[-3:])

    try:
        response = client.messages.create(
            model=settings.classifier_model,
            max_tokens=100,
            temperature=settings.classifier_temperature,
            messages=[{
                "role": "user",
                "content": (
                    f"Clasifica este mensaje en una categoría.\n\n"
                    f"Categorías:\n{categories}\n\n"
                    f'Mensaje: "{message}"{history_text}\n\n'
                    f'Responde SOLO JSON: {{"skill": "codigo", "subcategory": "codigo_sub", "confidence": 0.0-1.0}}'
                ),
            }],
        )
        text = response.content[0].text if response.content else ""
        parsed = json.loads(text.strip())
        if parsed.get("skill") in SKILL_REGISTRY:
            return ClassificationResult(
                skill_code=parsed["skill"],
                subcategory_code=parsed.get("subcategory"),
                confidence=parsed.get("confidence", 0.7),
                method="llm",
            )
    except Exception as e:
        logger.error(f"LLM classification failed: {e}")

    return None


def classify_message(message: str, history: list[str] | None = None) -> ClassificationResult:
    """Classify with keyword fast-path, LLM fallback."""
    kw_result = classify_by_keywords(message)
    if kw_result and kw_result.confidence >= 0.8:
        return kw_result

    llm_result = classify_by_llm(message, history)
    if llm_result:
        return llm_result

    if kw_result:
        return kw_result

    first_skill = next(iter(SKILL_REGISTRY))
    return ClassificationResult(skill_code=first_skill, confidence=0.1, method="keyword")
