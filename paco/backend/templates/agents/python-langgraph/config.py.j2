"""
{{ agent.display_name }} — Configuration
Generated by PACO
"""

import os

from pydantic_settings import BaseSettings


class Settings(BaseSettings):
    """Agent settings from environment."""

    # Agent
    agent_name: str = "{{ agent.name }}"
    display_name: str = "{{ agent.display_name }}"
    port: int = {{ agent.port }}

    # Anthropic
    anthropic_api_key: str = ""
    model: str = "claude-sonnet-4-5-20250929"
    max_tokens: int = 4096

    # Classifier
    classifier_model: str = "{{ classifier.get('model', 'claude-sonnet-4-5-20250929') }}"
    classifier_temperature: float = {{ classifier.get("temperature", 0.1) }}

    # Memory
    memory_retention_days: int = {{ memory.get("retention_days", 30) }}
    memory_max_messages: int = {{ memory.get("max_messages", 20) }}
    memory_db_path: str = "./data/memory.db"

    # MCP Servers
{% for name, server in mcp_servers.items() %}
    mcp_{{ name | replace('-', '_') }}_url: str = "{{ server.url or '' }}"
{% endfor %}

{% if webhooks.get("chatwoot") %}
    # Chatwoot
    chatwoot_url: str = "{{ webhooks.chatwoot.get('url', '') }}"
    chatwoot_token: str = ""
{% endif %}

    class Config:
        env_file = ".env"
        case_sensitive = False


settings = Settings()
