import logging
from typing import Any

import httpx

from config import settings

logger = logging.getLogger(__name__)

MCP_SERVER_URLS: dict[str, str] = {
{% for name, server in mcp_servers.items() %}
    "{{ name }}": settings.mcp_{{ name | replace('-', '_') }}_url,
{% endfor %}
}


async def call_mcp_tool(server_name: str, tool_name: str, arguments: dict[str, Any]) -> dict[str, Any]:
    """Call a tool via its MCP server."""
    url = MCP_SERVER_URLS.get(server_name)
    if not url:
        return {"success": False, "error": f"MCP server '{server_name}' not configured"}

    try:
        async with httpx.AsyncClient(timeout=30.0) as client:
            response = await client.post(
                f"{url}/tools/call",
                json={"name": tool_name, "arguments": arguments},
            )
            response.raise_for_status()
            data = response.json()
            content = data.get("content", [{}])[0].get("text", "")
            try:
                return {"success": True, "data": __import__("json").loads(content)}
            except (ValueError, TypeError):
                return {"success": True, "data": content or data}
    except Exception as e:
        logger.error(f"MCP tool {tool_name} failed: {e}")
        return {"success": False, "error": str(e)}


{% for tool in tools %}
