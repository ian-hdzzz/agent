"""
{{ agent.display_name }} — Skill Registry
Generated by PACO
"""

from dataclasses import dataclass, field
from typing import Dict, List, Optional

from prompts import CONVERSATION_RULES, {% for skill in skills %}PROMPT_{{ skill.code | upper }}{{ ", " if not loop.last else "" }}{% endfor %}


@dataclass
class Subcategory:
    code: str
    name: str
    priority: str = "medium"
    group: Optional[str] = None


@dataclass
class Skill:
    code: str
    name: str
    description: str
    prompt: str
    tools: List[str] = field(default_factory=list)
    subcategories: List[Subcategory] = field(default_factory=list)
    keywords: List[str] = field(default_factory=list)
    priority: str = "medium"
    # Anthropic Agent Skills spec
    resource_paths: List[str] = field(default_factory=list)
    license: Optional[str] = None
    metadata: dict = field(default_factory=dict)

    @property
    def full_prompt(self) -> str:
        if CONVERSATION_RULES:
            return CONVERSATION_RULES + "\n\n" + self.prompt
        return self.prompt


SKILL_REGISTRY: dict[str, Skill] = {
{% for skill in skills %}
    "{{ skill.code }}": Skill(
        code="{{ skill.code }}",
        name="{{ skill.name }}",
        description="{{ skill.description }}",
        prompt=PROMPT_{{ skill.code | upper }},
        tools={{ skill.tool_names | tojson }},
        subcategories=[
{% for sub in skill.subcategories %}
            Subcategory(code="{{ sub.code }}", name="{{ sub.name }}", priority="{{ sub.get('priority', 'medium') }}"{{ ', group="' + sub.group + '"' if sub.get("group") else "" }}),
{% endfor %}
        ],
        keywords={{ skill.keywords | tojson }},
        priority="{{ skill.priority }}",
        resource_paths={{ skill.resource_files.keys() | list | tojson }},
{% if skill.license %}
        license="{{ skill.license }}",
{% endif %}
        metadata={{ skill.skill_metadata | tojson }},
    ),
{% endfor %}
}
