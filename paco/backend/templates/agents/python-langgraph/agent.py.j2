import logging
from typing import Any, TypedDict

import anthropic

from classifier import classify_message
from config import settings
from skills import SKILL_REGISTRY
from tools import {% for tool in tools %}{{ tool.name }}{{ ", " if not loop.last else "" }}{% endfor %}

logger = logging.getLogger(__name__)


class AgentState(TypedDict):
    messages: list[dict[str, str]]
    conversation_id: str
    contact_id: str | None
    skill_code: str | None
    tools_used: list[str]


TOOL_FUNCTIONS: dict[str, Any] = {
{% for tool in tools %}
    "{{ tool.name }}": {{ tool.name }},
{% endfor %}
}


async def process_message(
    message: str,
    conversation_id: str,
    contact_id: str | None = None,
    history: list[dict[str, str]] | None = None,
) -> dict[str, Any]:
    """Process a user message through classify -> skill -> tools -> response."""

    # Classify
    user_history = [m["content"] for m in (history or []) if m["role"] == "user"]
    classification = classify_message(message, user_history)
    skill = SKILL_REGISTRY.get(classification.skill_code)

    if not skill:
        return {
            "response": "Disculpa, ocurrió un error. Por favor intenta de nuevo.",
            "conversation_id": conversation_id,
        }

    # Build messages
    messages = list(history or [])
    messages.append({"role": "user", "content": message})

    # Build tool definitions for this skill
    tool_defs = []
    for tool_name in skill.tools:
        if tool_name in TOOL_FUNCTIONS:
            tool_defs.append({
                "name": tool_name,
                "description": f"Tool: {tool_name}",
                "input_schema": {"type": "object", "properties": {}},
            })

    # Call Claude
    client = anthropic.Anthropic(api_key=settings.anthropic_api_key)
    tools_used = []

    api_messages = [{"role": m["role"], "content": m["content"]} for m in messages]

    response = client.messages.create(
        model=settings.model,
        max_tokens=settings.max_tokens,
        system=skill.full_prompt,
        messages=api_messages,
        tools=tool_defs if tool_defs else anthropic.NOT_GIVEN,
    )

    # Handle tool use loop
    iterations = 0
    while response.stop_reason == "tool_use" and iterations < 10:
        iterations += 1

        tool_results = []
        for block in response.content:
            if block.type == "tool_use":
                tool_fn = TOOL_FUNCTIONS.get(block.name)
                if tool_fn:
                    import asyncio
                    result = await tool_fn(**block.input)
                    tools_used.append(block.name)
                    tool_results.append({
                        "type": "tool_result",
                        "tool_use_id": block.id,
                        "content": __import__("json").dumps(result.get("data", result.get("error", ""))),
                    })

        api_messages.append({"role": "assistant", "content": response.content})
        api_messages.append({"role": "user", "content": tool_results})

        response = client.messages.create(
            model=settings.model,
            max_tokens=settings.max_tokens,
            system=skill.full_prompt,
            messages=api_messages,
            tools=tool_defs if tool_defs else anthropic.NOT_GIVEN,
        )

    # Extract text
    response_text = ""
    for block in response.content:
        if hasattr(block, "text"):
            response_text += block.text

    return {
        "response": response_text or "Disculpa, ocurrió un error.",
        "conversation_id": conversation_id,
        "skill_used": classification.skill_code,
        "tools_used": tools_used,
    }
