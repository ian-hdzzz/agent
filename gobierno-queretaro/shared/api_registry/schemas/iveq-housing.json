{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IVEQ Housing API Schemas",
  "description": "Request/response schemas for housing services",
  "definitions": {
    "get_debt_status_input": {
      "type": "object",
      "required": ["property_id"],
      "properties": {
        "property_id": { "type": "string" }
      }
    },
    "get_debt_status_output": {
      "type": "object",
      "properties": {
        "property_id": { "type": "string" },
        "has_debt": { "type": "boolean" },
        "total_debt": { "type": "number" },
        "certificate_available": { "type": "boolean" }
      }
    },
    "create_appointment_input": {
      "type": "object",
      "required": ["date", "time", "purpose"],
      "properties": {
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$" },
        "purpose": { "type": "string" }
      }
    },
    "create_appointment_output": {
      "type": "object",
      "properties": {
        "appointment_id": { "type": "string" },
        "confirmation_code": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" }
      }
    },
    "check_eligibility_input": {
      "type": "object",
      "required": ["curp"],
      "properties": {
        "curp": { "type": "string" }
      }
    },
    "check_eligibility_output": {
      "type": "object",
      "properties": {
        "eligible": { "type": "boolean" },
        "programs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "program_id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
