# ============================================
# Gobierno Querétaro - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# CEA Proxy URL (optional - for CEA SOAP calls)
CEA_PROXY_URL=

# CEA SOAP credentials (for water service API)
CEA_SOAP_USERNAME=WSGESTIONDEUDA
CEA_SOAP_PASSWORD=WSGESTIONDEUDA

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# PostgreSQL (defaults work with docker-compose)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=gobierno

# Voice Gateway (optional - for voice calls)
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9
ELEVENLABS_MODEL_ID=eleven_turbo_v2
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=es-419

# PACO Admin API (required for /admin endpoints)
PACO_ADMIN_API_KEY=your-secure-admin-key-here

# Paco JWT Secret (must match Paco backend's SECRET_KEY to accept JWT tokens)
# When set, admin endpoints accept Authorization: Bearer <jwt> with admin role
PACO_JWT_SECRET=

# Encryption key for Fernet (auto-generated if empty, but recommended to set)
# ENCRYPTION_KEY=

# Rate Limiting (format: "N/minute", "N/second", "N/hour")
RATE_LIMIT_ROUTE=60/minute
RATE_LIMIT_CLASSIFY=120/minute

# External integrations (optional)
# CHATWOOT_API_KEY=
# CHATWOOT_ACCOUNT_ID=
# CHATWOOT_BASE_URL=
