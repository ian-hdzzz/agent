# ============================================
# Maria V2 - Environment Configuration
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# CEA API Configuration
CEA_API_BASE=https://aquacis-cf.ceaqueretaro.gob.mx/Comercial/services
CEA_PROXY_URL=

# PostgreSQL Database (for tickets)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=agora_production
PGPOOL_MAX=10

# Chatwoot Integration (optional)
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=

# Memory Store
MEMORY_DB_PATH=./data/maria_memory.db

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Budget Controls
MAX_BUDGET_PER_MESSAGE=0.50
MAX_BUDGET_PER_CONVERSATION=2.00
