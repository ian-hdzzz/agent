# ============================================
# CEA Agent Server - Environment Variables
# ============================================

# OpenAI API Key (required)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI Model (optional, defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Server port (optional, defaults to 3000)
PORT=3000

# CEA API Proxy (optional - for whitelisted IP access)
# If CEA API only accepts requests from specific IPs, configure a proxy
# Example: CEA_PROXY_URL=http://10.128.0.7:3128
CEA_PROXY_URL=

# PostgreSQL - AGORA Database (required for ticket operations)
PGHOST=136.107.45.255
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_postgres_password
PGDATABASE=agora_production
PGPOOL_MAX=10

# Agent Configuration
# Account ID for ticket creation in Chatwoot
AGENT_ACCOUNT_ID=1

# Evolution API (for WhatsApp integration)
EVOLUTION_API_URL=https://evolution.whoopflow.com
EVOLUTION_API_KEY=your_evolution_api_key

# Test contract number for API testing (optional)
TEST_CONTRACT=523160
PORCOBRAR_API_URL=https://stage.api.porcobrar.com
